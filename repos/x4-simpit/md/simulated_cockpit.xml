<?xml version="1.0" encoding="utf-8"?>
<mdscript name="SimulatedCockpit"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="file:///games/linux/X4_Foundations_extracted/libraries/md.xsd">
    <cues>
        <!--TODO:
        find out how referencing this works-->
        <library name="Lib_Simpit_Get">
            <!--<param
            name="module" default="Status" />-->
            <actions>
                <debug_text text="'SimPit: SimPit_Get_' + $module" chance="$DebugChance" />
                <set_value name="$logfile" exact="'SimPit-' + md.$SystemTimeAtGamestart" />
                <debug_to_file name="$logfile" directory="'SimPit'"
                    text="'SimPit_Get_Ship' + $module +': ' + player.target" output="true"
                    append="true" />
                <raise_lua_event name="'simPit.get'" param="$module" />
            </actions>
        </library>
        <cue name="OnLuaLoaderReady">
            <conditions>
                <event_ui_triggered screen="'Lua_Loader'" control="'Ready'" />
            </conditions>
            <actions>
                <set_value name="$DebugChance" exact="100" />
                <set_value name="$logfile" exact="'SimPit-' + md.$SystemTimeAtGamestart" />
                <debug_to_file name="$logfile" directory="'SimPit'"
                    text="'Asking Lua Loader to load extensions/x4-simpit/pipe_external.txt with Python Pipe Server (Windows only)'"
                    output="true" append="true" chance="$DebugChance" />
                <debug_text
                    text="'Asking Lua Loader to load extensions/x4-simpit/pipe_external.txt with Python Pipe Server (Windows only)'"
                    chance="$DebugChance" />
                <raise_lua_event name="'Lua_Loader.Load'"
                    param="'extensions.x4-simpit.lua.Simulated_Cockpit'" />
            </actions>
        </cue>
        <cue name="OnLuaLoaderReadyCompleted">
            <conditions>
                <event_cue_completed cue="OnLuaLoaderReady" />
            </conditions>
            <actions>
                <set_value name="$DebugChance" exact="100" />
                <set_value name="$logfile" exact="'SimPit-' + md.$SystemTimeAtGamestart" />
                <debug_to_file name="$logfile" directory="'SimPit'"
                    text="'[x]'" output="false" append="true"
                    chance="$DebugChance" />
                <debug_text text="'[x]'" chance="$DebugChance" />
                <reset_cue cue="OnLuaLoaderReady" />
                <reset_cue cue="this" />
            </actions>
        </cue>
        <!--
          Register the pipe server with the python host.
        -->
        <cue name="Register_Pipe_Server" instantiate="true">
            <conditions>
                <event_cue_signalled cue="md.Pipe_Server_Host.Reloaded" />
            </conditions>
            <actions>
                <set_value name="$DebugChance" exact="100" />
                <debug_text text="'Registering extensions/x4-simpit/pipe_external.txt with Python Pipe Server (Windows only)'"  chance="$DebugChance" />
                <signal_cue_instantly cue="md.Pipe_Server_Host.Register_Module"
                    param="'extensions/x4-simpit/pipe_external.txt'" />
                <reset_cue cue="this" />
            </actions>
        </cue>
        <cue name="SimPit_Main">
            <conditions>
                <check_any>
                    <event_cue_signalled cue="md.Setup.GameStart" />
                    <event_universe_generated />
                </check_any>
            </conditions>
            <actions>
                <set_value name="$DebugChance" exact="100" />
                <set_value name="$logfile" exact="'SimPit-' + md.$SystemTimeAtGamestart" />
                <debug_to_file name="$logfile" directory="'SimPit'"
                    text="'Game was started/reloaded'" output="true" append="true"
                    chance="$DebugChance" />
                <debug_text text="'Game was started/reloaded'" chance="$DebugChance" />
            </actions>
            <cues>
                <cue name="SimPit_writeMessages" instantiate="true">
                    <conditions>
                        <event_ui_triggered screen="'simPit.write'" control="'data_feed'" />
                    </conditions>
                    <actions>
                        <set_value name="$DebugChance" exact="5" />
                        <debug_text text="'SimPit: SimPit_writeMessages '" chance="$DebugChance" />
                        <set_value name="$data" exact="event.param3" />
                        <debug_text text="'SimPit: $data ' + $data" chance="$DebugChance" />
                        <signal_cue_instantly cue="md.Named_Pipes.Write"
                            param="table[$pipe='x4simpit', $msg=$data]" />
                    </actions>
                </cue>
                <!-- https://elite-journal.readthedocs.io/en/latest/Status%20File/ -->
                <!-- Written _very often_ because it holds vital ship data -->
                <cue name="SimPit_Get_Status" checkinterval="1s">
                    <delay min="200ms" max="500ms" />
                    <actions>
                        <debug_text text="'SimPit_Get_Status'" chance="5" />
                        <raise_lua_event name="'simPit.get'" param="'Status'" />
                        <reset_cue cue="this" />
                    </actions>
                </cue>

                <cue name="SimPit_Get_Receive_Text" checkinterval="1s">
                    <delay min="500ms" max="1s" />
                    <actions>
                        <debug_text text="'SimPit_Get_Receive_Text'" chance="5" />
                        <raise_lua_event name="'simPit.get'" param="'ReceiveText'" />
                        <reset_cue cue="this" />
                    </actions>
                </cue>
                <!-- FIXME: this triggers _very often_ on /reloadui - why?? -->
                <!-- https://elite-journal.readthedocs.io/en/latest/Startup/#commander -->
                <cue name="SimPit_Get_Commander">
                    <conditions>
                        <event_universe_generated />
                    </conditions>
                    <!-- Give the pipe some time to reconnect without flooding it on game start/load -->
                    <delay min="2s" max="5s" />
                    <actions>
                        <debug_text text="'SimPit_Get_Commander ' + player.name"
                            chance="100" />
                        <raise_lua_event name="'simPit.get'" param="'Commander'" />
                        <reset_cue cue="this" />
                    </actions>
                </cue>
                <cue name="SimPit_Get_Loadout_On_Universe_Generated">
                    <conditions>
                        <event_universe_generated />
                    </conditions>
                    <!-- Give the pipe some time to reconnect without flooding it on game start/load -->
                    <delay min="2s" max="5s" />
                    <actions>
                        <signal_cue cue="SimPit_Get_Loadout" />
                        <reset_cue cue="this" />
                    </actions>
                </cue>
                <cue name="SimPit_Get_Loadout">
                    <conditions>
                        <check_any>
                            <event_player_started_control />
                            <event_cue_signalled />
                        </check_any>
                    </conditions>
                    <actions>
                        <do_if value="player.ship">
                            <raise_lua_event name="'simPit.get'" param="'Loadout'" />
                        </do_if>
                        <reset_cue cue="this" />
                    </actions>
                </cue>
                <cue name="SimPit_Playercontrol_Stopped">
                    <conditions>
                        <event_player_stopped_control />
                    </conditions>
                    <actions>
                        <debug_text text="'Weapon: Player gave up control'" chance="$DebugChance" />
                        <clear_group group="$playershipweapons" />
                        <reset_cue cue="SimPit_Playercontrol_Started" />
                        <cancel_cue cue="SimPit_Get_HeatWarning" />
                        <reset_cue cue="SimPit_Get_HeatWarning" />
                        <debug_text text="'Weapon cue Paused'" />
                    </actions>
                </cue>
                <cue name="SimPit_Playercontrol_Started">
                    <conditions>
                        <event_player_started_control />
                    </conditions>
                    <actions>
                        <debug_text text="'Weapon: Player taking control'" chance="$DebugChance" />
                        <reset_cue cue="SimPit_Playercontrol_Stopped" />
                        <add_to_group groupname="$playershipweapons"
                            list="player.ship.weapons.operational.list" />
                        <do_for_each in="$playershipweapons">
                            <debug_text text="'Weapon group ' + loop.index + ' exists'"
                                chance="$DebugChance" />
                            <signal_cue_instantly cue="SimPit_Get_HeatWarning" param="loop.element" />
                        </do_for_each>
                    </actions>
                </cue>
                <cue name="SimPit_Get_HeatWarning" instantiate="true">
                    <conditions>
                        <event_cue_signalled />
                    </conditions>
                    <actions>
                        <debug_text text="'Weapon cue SimPit_Get_HeatWarning triggerd '"
                            chance="$DebugChance" />
                        <set_value name="$weapongroup" exact="event.param" />
                    </actions>
                    <cues>
                        <cue name="SimPit_Get_HeatWarning_Group" instantiate="true">
                            <conditions>
                                <event_weapon_overheated object="$weapongroup" />
                            </conditions>
                            <actions>
                                <debug_text text="'Weapon overheated ' + $weapongroup"
                                    chance="$DebugChance" />
                                <raise_lua_event name="'simPit.get'" param="'HeatWarning'" />
                            </actions>
                        </cue>
                    </cues>
                </cue>
                <cue name="SimPit_Get_Docked">
                    <conditions>
                        <event_object_docked group="global.$PlayerShipsGroup" />
                    </conditions>
                    <actions>
                        <debug_text text="'Player docked'" chance="100" />
                        <raise_lua_event name="'simPit.get'" param="'Docked'" />
                        <reset_cue cue="this" />
                    </actions>
                </cue>
                <cue name="SimPit_Get_Undocked">
                    <conditions>
                        <!-- TODO: may be of use to forward: -->
                        <!-- param = dock, param2 = zone, param3 = docking bay -->
                        <event_object_undocked group="global.$PlayerShipsGroup" />
                    </conditions>
                    <actions>
                        <!-- TODO: forward event.param to simPit to read the old context from there  -->
                        <debug_text text="'Player undocked: ' + event.param" chance="100" />
                        <raise_lua_event name="'simPit.get'" param="'Undocked;'+event.param" />
                        <reset_cue cue="this" />
                    </actions>
                </cue>
                <cue name="SimPit_Get_Countermeasures">
                    <conditions>
                        <check_any>
                            <event_player_out_of_ammo />
                            <event_object_launched_countermeasure group="global.$PlayerShipsGroup" />
                        </check_any>
                    </conditions>
                    <actions>
                        <debug_text text="'Countermeasures launched'" chance="100" />
                        <!-- Countermeasure ammo is part of the Loadout info -->
                        <raise_lua_event name="'simPit.get'" param="'Loadout'" />
                        <reset_cue cue="this" />
                    </actions>
                </cue>
                <cue name="SimPit_Get_UnderAttackByMissile" instantiate="true">
                    <conditions>
                        <event_object_incoming_missile group="global.$PlayerContainerGroup" />
                        <check_value
                            value="event.object.isclass.ship and event.object.isplayerowned" />
                        <check_age min="@$lasttime + param.cooldown.incoming_missile" />
                    </conditions>
                    <actions>
                        <debug_text text="'SimPit: Incoming missile'" chance="100" />
                        <raise_lua_event name="'simPit.get'" param="'UnderAttack'" />
                        <set_value name="$lasttime" exact="player.age" />
                    </actions>
                </cue>
                <!-- https://www.egosoft.com:8444/confluence/display/XRWIKI/Mission+Director+Guide -->
                <!-- https://elite-journal.readthedocs.io/en/latest/Combat/#shiptargetted -->
                <cue name="SimPit_Get_ShipTargeted" instantiate="true">
                    <conditions>
                        <check_any>
                            <event_player_changed_target />
                            <event_player_killed_object />
                        </check_any>
                    </conditions>
                    <!-- Repeat -->
                    <actions>
                        <raise_lua_event name="'simPit.get'" param="'ShipTargeted'" />
                        <debug_text text="'Player changed target'" chance="$DebugChance" />
                        <set_value name="$target" exact="event.param" />
                        <do_if value="($target != null) and ($target != $last_target)">
                            <debug_text text="'New target ' + $target"
                                chance="$DebugChance" />
                            <debug_text text="'Going ONLINE'" chance="$DebugChance" />
                        </do_if>
                        <do_else>
                            <!--target
                            deselected, final read -->
                            <debug_text text="'No more targets, going OFFLINE'"
                                chance="$DebugChance" />
                            <cancel_cue cue="this" />
                        </do_else>
                    </actions>
                    <cues>
                        <!-- This should instantiate and check with interval until target becomes
                        null
                        when this -->
                        <!-- cancels itself after a final read (to get empty targetting data) -->
                        <!-- FIXME: this does not work if target only changes and spawns new
                        instances -->
                        <!-- It only deactivates all when targets gets nulled !!-->
                        <cue name="SimPit_Get_ShipTargeted_Repeat" instantiate="true"
                            onfail="cancel">
                            <conditions>
                                <check_value value="$target != null" />
                            </conditions>
                            <delay min="500ms" max="1s" />
                            <actions>
                                <do_if
                                    value="($target != null and $last_target == null) or ($target == $last_target)">
                                    <!--target
                                    exists, keep read -->
                                    <debug_text text="'Going'" chance="$DebugChance" />
                                    <raise_lua_event name="'simPit.get'" param="'ShipTargeted'" />
                                    <reset_cue cue="this" />
                                </do_if>
                                <do_else>
                                    <debug_text text="'Going OFFLINE'" chance="$DebugChance" />
                                    <raise_lua_event name="'simPit.get'" param="'ShipTargeted'" />
                                    <cancel_cue cue="this" />
                                </do_else>
                                <set_value name="$last_target" exact="$target" />
                            </actions>
                        </cue>
                    </cues>
                </cue>

            </cues>
        </cue>
        <cue name="Server_Reader_Wrapper">
            <cues>
                <cue name="Server_Reader" ref="md.Pipe_Server_Lib.Server_Reader">
                    <param name="Actions_On_Reload" value="Actions_On_Reload" />
                    <param name="Actions_On_Connect" value="Actions_On_Connect" />
                    <param name="Actions_On_Read" value="Actions_On_Read" />
                </cue>
            </cues>
        </cue>
        <library name="Actions_On_Reload">
            <actions>
                <set_value name="$Pipe_Name" exact="'x4simpit'" />
                <signal_cue cue="$Start_Reading" />
                <set_value name="$server_connected" exact="1" />
                <set_value name="$DebugChance" exact="100" />
                <debug_text text="'SimPit: Received on reload'" chance="$DebugChance" />
            </actions>
        </library>
        <library name="Actions_On_Connect">
            <actions>
                <signal_cue cue="$Start_Reading" />
                <set_value name="$server_connected" exact="1" />
                <set_value name="$DebugChance" exact="100" />
                <debug_text text="'SimPit: Received on connect'" chance="$DebugChance" />
            </actions>
        </library>
        <library name="Actions_On_Read">
            <actions>
                <set_value name="$DebugChance" exact="100" />
                <!-- Someone send us something => we assume we're connect -->
                <set_value name="$server_connected" exact="1" />
                <debug_text text="'SimPit: Received message: %s.'.[event.param]"
                    chance="$DebugChance" />
                <raise_lua_event name="'simPit.read'" param="event.param" />
            </actions>
        </library>
    </cues>
</mdscript>