<?xml version="1.0" encoding="utf-8"?>

<aiscript name="jp.lib.ConvertARGBtoHex" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="aiscripts.xsd" version="1">

   <params>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <param name="ALPHA" default="255"/>
      <param name="RED"   default="3"/>
      <param name="GREEN" default="161"/>
      <param name="BLUE"  default="252"/>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <param name="debugchance" default="0"/>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
   </params>

   <init>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <set_value name="$_Ship" exact="this.ship"/>
      <set_value name="$_DefaultOrderParamRef" exact="if $_Ship.defaultorder.id == 'Assist' then $_Ship.commander.defaultorder else $_Ship.defaultorder"/>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <set_value name="$DEBUG" exact="@$_DefaultOrderParamRef.$DEBUG"/>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <do_if value="$DEBUG gt 0">
         <set_value name="$_DebugFolderName" exact="@$_DefaultOrderParamRef.$DEBUG_FOLDER_NAME"/>
         <set_value name="$_DebugScriptName" exact="'jp.lib.ConvertARGBtoHex'"/>
         <set_value name="$_DebugFileName" exact="$_Ship.idcode + '.' + $_DebugScriptName + '.xml.log'"/>
      </do_if>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
   </init>

   <attention min="unknown">
      <actions>

         <label name="INIT_LBL"/>
         <do_if value="$DEBUG gt 0">
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~'" append="false"/>
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'[' + player.systemtime.{'%F - %X'} + '] ' + '~~ ' + $_DebugScriptName + '.xml ~ SCRIPT_START ~~' + '\n'"/>
         </do_if>

         <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->

         <create_list name="$TempDecimalNumbers"/>
         <create_list name="$ConstructedHexNumber"/>
         <append_list_elements name="$TempDecimalNumbers" other="[$ALPHA, $RED, $GREEN, $BLUE]"/>

         <do_for_each name="$_DecimalNumber" in="$TempDecimalNumbers">
            <do_if value="$_DecimalNumber != 0">
               <set_value name="$ActualDecimal" exact="($_DecimalNumber)i"/>
               <create_list name="$TempHexNumber"/>
               <do_while value="$ActualDecimal != 0">
                  <wait exact="1ms"/>
                  <set_value name="$Remainder" exact="$ActualDecimal % 16"/>
                  <do_if value="$Remainder le 9">
                     <append_to_list name="$TempHexNumber" exact="'%1'.[$Remainder]"/>
                  </do_if>
                  <do_elseif value="$Remainder" exact="10">
                     <append_to_list name="$TempHexNumber" exact="'A'"/>
                  </do_elseif>
                  <do_elseif value="$Remainder" exact="11">
                     <append_to_list name="$TempHexNumber" exact="'B'"/>
                  </do_elseif>
                  <do_elseif value="$Remainder" exact="12">
                     <append_to_list name="$TempHexNumber" exact="'C'"/>
                  </do_elseif>
                  <do_elseif value="$Remainder" exact="13">
                     <append_to_list name="$TempHexNumber" exact="'D'"/>
                  </do_elseif>
                  <do_elseif value="$Remainder" exact="14">
                     <append_to_list name="$TempHexNumber" exact="'E'"/>
                  </do_elseif>
                  <do_elseif value="$Remainder" exact="15">
                     <append_to_list name="$TempHexNumber" exact="'F'"/>
                  </do_elseif>
                  <set_value name="$ActualDecimal" exact="$ActualDecimal / 16"/>
               </do_while>
               <do_if value="$TempHexNumber.count == 0">
                  <append_list_elements name="$TempHexNumber" other="['0', '0']"/>
               </do_if>
               <do_elseif value="$TempHexNumber.count == 1">
                  <append_to_list name="$TempHexNumber" exact="'0'"/>
               </do_elseif>
               <do_for_each name="$Number" in="$TempHexNumber" reverse="true">
                  <append_to_list name="$ConstructedHexNumber" exact="$Number"/>
               </do_for_each>
            </do_if>
            <do_else>
               <append_list_elements name="$ConstructedHexNumber" other="['0', '0']"/>
            </do_else>
         </do_for_each>

         <set_value name="$_HexColorString" exact="'\033#%1%2%3%4%5%6%7%8#'.[$ConstructedHexNumber.{1}, $ConstructedHexNumber.{2}, $ConstructedHexNumber.{3}, $ConstructedHexNumber.{4}, $ConstructedHexNumber.{5}, $ConstructedHexNumber.{6}, $ConstructedHexNumber.{7}, $ConstructedHexNumber.{8}]"/>

         <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->

         <label name="END_LBL"/>
         <do_if value="$DEBUG gt 0">
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'[' + player.systemtime.{'%F - %X'} + '] ' + '~~ ' + $_DebugScriptName + '.xml ~ SCRIPT_END ~~'"/>
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~\n'"/>
         </do_if>

         <return value="$_HexColorString"/>

      </actions>
   </attention>

   <on_abort>
   </on_abort>

</aiscript><?xml version="1.0" encoding="utf-8"?>

<aiscript name="jp.lib.FindStationToEquipAt" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="aiscripts.xsd">

   <params>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <param name="debugchance" default="0"/>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
   </params>

   <init>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <set_value name="$_Ship" exact="this.ship"/>
      <set_value name="$_DefaultOrderParamRef" exact="if $_Ship.defaultorder.id == 'Assist' then $_Ship.commander.defaultorder else $_Ship.defaultorder"/>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <set_value name="$DEBUG" exact="@$_DefaultOrderParamRef.$DEBUG"/>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <do_if value="$DEBUG gt 0">
         <set_value name="$_DebugFolderName" exact="@$_DefaultOrderParamRef.$DEBUG_FOLDER_NAME"/>
         <set_value name="$_DebugScriptName" exact="'jp.lib.FindStationToEquipAt'"/>
         <set_value name="$_DebugFileName" exact="$_Ship.idcode + '.' + $_DebugScriptName + '.xml.log'"/>
      </do_if>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
   </init>

   <attention min="unknown">
      <actions>

         <label name="INIT_LBL"/>
         <do_if value="$DEBUG gt 0">
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~'" append="false"/>
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'[' + player.systemtime.{'%F - %X'} + '] ' + '~~ ' + $_DebugScriptName + '.xml ~ SCRIPT_START ~~' + '\n'"/>
         </do_if>

         <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->

         <set_command_action commandaction="commandaction.calculating"/>

         <create_list name="$_FoundStations"/>
         <find_station name="$_FoundStations" space="player.galaxy" multiple="true">
            <match knownto="$_Ship.owner"/>
            <match checkoperational="true"/>
            <match cansupplyclass="$_Ship.class"/>
            <match canequipclass="$_Ship.class"/>
            <match hascontrolentity="controlpost.shiptrader"/>
            <match_relation_to faction="$_Ship.owner" comparison="ge" relation="dock"/>
         </find_station>

         <do_if value="$_FoundStations.count gt 1">
            <run_script name="'jp.lib.SortByEstimatedTravelTime'" result="$_FoundStations">
               <param name="LIST" value="$_FoundStations"/>
            </run_script>
         </do_if>

         <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->

         <label name="END_LBL"/>
         <do_if value="$DEBUG gt 0">
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'[' + player.systemtime.{'%F - %X'} + '] ' + '~~ ' + $_DebugScriptName + '.xml ~ SCRIPT_END ~~'"/>
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~\n'"/>
         </do_if>

         <return value="$_FoundStations"/>

      </actions>
   </attention>

   <on_abort>
   </on_abort>

</aiscript><?xml version="1.0" encoding="utf-8"?>

<aiscript name="jp.lib.GetFactionColorCode" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="aiscripts.xsd">

   <params>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <param name="FACTION" default="null"/>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <param name="debugchance" default="0"/>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
   </params>

   <init>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <set_value name="$_Ship" exact="this.ship"/>
      <set_value name="$_DefaultOrderParamRef" exact="if $_Ship.defaultorder.id == 'Assist' then $_Ship.commander.defaultorder else $_Ship.defaultorder"/>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <set_value name="$DEBUG" exact="@$_DefaultOrderParamRef.$DEBUG"/>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <do_if value="$DEBUG gt 0">
         <set_value name="$_DebugFolderName" exact="@$_DefaultOrderParamRef.$DEBUG_FOLDER_NAME"/>
         <set_value name="$_DebugScriptName" exact="'jp.lib.GetFactionColorCode'"/>
         <set_value name="$_DebugFileName" exact="$_Ship.idcode + '.' + $_DebugScriptName + '.xml.log'"/>
      </do_if>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
   </init>

   <attention min="unknown">
      <actions>

         <label name="INIT_LBL"/>
         <do_if value="$DEBUG gt 0">
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~'" append="false"/>
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'[' + player.systemtime.{'%F - %X'} + '] ' + '~~ ' + $_DebugScriptName + '.xml ~ SCRIPT_START ~~' + '\n'"/>
         </do_if>

         <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->

         <set_command_action commandaction="commandaction.calculating"/>

         <set_value name="$_FactionColorCode" exact="'\033#FFFFFFFF#'"/>
         <do_if value="$FACTION == faction.player">
            <set_value name="$_FactionColorCode" exact="'\033#FF39ff40#'"/>
         </do_if>
         <do_elseif value="$FACTION == faction.alliance">
            <set_value name="$_FactionColorCode" exact="'\033#FFb03cca#'"/>
         </do_elseif>
         <do_elseif value="$FACTION == faction.antigone">
            <set_value name="$_FactionColorCode" exact="'\033#FF5097de#'"/>
         </do_elseif>
         <do_elseif value="$FACTION == faction.argon">
            <set_value name="$_FactionColorCode" exact="'\033#FF0055ff#'"/>
         </do_elseif>
         <do_elseif value="$FACTION == faction.buccaneers">
            <set_value name="$_FactionColorCode" exact="'\033#FF5900ff#'"/>
         </do_elseif>
         <do_elseif value="$FACTION == faction.civilian">
            <set_value name="$_FactionColorCode" exact="'\033#FF979797#'"/>
         </do_elseif>
         <do_elseif value="$FACTION == faction.criminal">
            <set_value name="$_FactionColorCode" exact="'\033#FFc90000#'"/>
         </do_elseif>
         <do_elseif value="$FACTION == faction.hatikvah">
            <set_value name="$_FactionColorCode" exact="'\033#FF20f6fd#'"/>
         </do_elseif>
         <do_elseif value="$FACTION == faction.holyorder">
            <set_value name="$_FactionColorCode" exact="'\033#FFff72ad#'"/>
         </do_elseif>
         <do_elseif value="$FACTION == faction.holyorderfanatic">
            <set_value name="$_FactionColorCode" exact="'\033#FF8a0101#'"/>
         </do_elseif>
         <do_elseif value="$FACTION == faction.khaak">
            <set_value name="$_FactionColorCode" exact="'\033#FFf0aeed#'"/>
         </do_elseif>
         <do_elseif value="$FACTION == faction.ministry">
            <set_value name="$_FactionColorCode" exact="'\033#FF94bc92#'"/>
         </do_elseif>
         <do_elseif value="$FACTION == faction.ownerless">
            <set_value name="$_FactionColorCode" exact="'\033#FF979797#'"/>
         </do_elseif>
         <do_elseif value="$FACTION == faction.paranid">
            <set_value name="$_FactionColorCode" exact="'\033#FF8000ff#'"/>
         </do_elseif>
         <do_elseif value="$FACTION == faction.scaleplate">
            <set_value name="$_FactionColorCode" exact="'\033#FF89823a#'"/>
         </do_elseif>
         <do_elseif value="$FACTION == faction.smuggler">
            <set_value name="$_FactionColorCode" exact="'\033#FFc90000#'"/>
         </do_elseif>
         <do_elseif value="$FACTION == faction.teladi">
            <set_value name="$_FactionColorCode" exact="'\033#FFa9c22e#'"/>
         </do_elseif>
         <do_elseif value="$FACTION == faction.trinity">
            <set_value name="$_FactionColorCode" exact="'\033#FFbf39d7#'"/>
         </do_elseif>
         <do_elseif value="$FACTION == faction.visitor">
            <set_value name="$_FactionColorCode" exact="'\033#FFffff00#'"/>
         </do_elseif>
         <do_elseif value="$FACTION == faction.xenon">
            <set_value name="$_FactionColorCode" exact="'\033#FFc90000#'"/>
         </do_elseif>
         <do_elseif value="$FACTION == faction.pioneers">
            <set_value name="$_FactionColorCode" exact="'\033#FF41aa9a#'"/>
         </do_elseif>
         <do_elseif value="$FACTION == faction.terran">
            <set_value name="$_FactionColorCode" exact="'\033#FFbcd0fb#'"/>
         </do_elseif>
         <do_elseif value="$FACTION == faction.yaki">
            <set_value name="$_FactionColorCode" exact="'\033#FFfe8dfa#'"/>
         </do_elseif>
         <do_elseif value="$FACTION == faction.court">
            <set_value name="$_FactionColorCode" exact="'\033#FFffd500#'"/>
         </do_elseif>
         <do_elseif value="$FACTION == faction.fallensplit">
            <set_value name="$_FactionColorCode" exact="'\033#FFfbb298#'"/>
         </do_elseif>
         <do_elseif value="$FACTION == faction.freesplit">
            <set_value name="$_FactionColorCode" exact="'\033#FFff9d00#'"/>
         </do_elseif>
         <do_elseif value="$FACTION == faction.split">
            <set_value name="$_FactionColorCode" exact="'\033#FFff691e#'"/>
         </do_elseif>
         <do_elseif value="$FACTION == faction.boron">
            <set_value name="$_FactionColorCode" exact="'\033#FF4dc4ff#'"/>
         </do_elseif>

         <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->

         <label name="END_LBL"/>
         <do_if value="$DEBUG gt 0">
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'[' + player.systemtime.{'%F - %X'} + '] ' + '~~ ' + $_DebugScriptName + '.xml ~ SCRIPT_END ~~'"/>
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~\n'"/>
         </do_if>

         <return value="$_FactionColorCode"/>

      </actions>
   </attention>

   <on_abort>
   </on_abort>

</aiscript><?xml version="1.0" encoding="utf-8"?>

<aiscript name="jp.lib.GetFactionRelationColorCode" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="aiscripts.xsd">

   <params>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <param name="FACTION_RELATION" default="null"/>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <param name="debugchance" default="0"/>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
   </params>

   <init>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <set_value name="$_Ship" exact="this.ship"/>
      <set_value name="$_DefaultOrderParamRef" exact="if $_Ship.defaultorder.id == 'Assist' then $_Ship.commander.defaultorder else $_Ship.defaultorder"/>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <set_value name="$DEBUG" exact="@$_DefaultOrderParamRef.$DEBUG"/>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <do_if value="$DEBUG gt 0">
         <set_value name="$_DebugFolderName" exact="@$_DefaultOrderParamRef.$DEBUG_FOLDER_NAME"/>
         <set_value name="$_DebugScriptName" exact="'jp.lib.GetFactionRelationColorCode'"/>
         <set_value name="$_DebugFileName" exact="$_Ship.idcode + '.' + $_DebugScriptName + '.xml.log'"/>
      </do_if>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
   </init>

   <attention min="unknown">
      <actions>

         <label name="INIT_LBL"/>
         <do_if value="$DEBUG gt 0">
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~'" append="false"/>
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'[' + player.systemtime.{'%F - %X'} + '] ' + '~~ ' + $_DebugScriptName + '.xml ~ SCRIPT_START ~~' + '\n'"/>
         </do_if>

         <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->

         <set_command_action commandaction="commandaction.calculating"/>

         <set_value name="$_Table" exact="table[]"/>
         <set_value name="$_Table.{-30}" exact="[[255,   0,   0], [255,   0,   0], 30.0,  1.0]" comment="[Red     to Red,     Initial value: 30.0, Transition range:  1.0]"/>
         <set_value name="$_Table.{-10}" exact="[[255,   0,   0], [255, 100, 100], 30.0, 20.0]" comment="[Red     to L.Red,   Initial value: 30.0, Transition range: 20.0]"/>
         <set_value name="$_Table.{0}"   exact="[[255, 100, 100], [192, 192, 192], 10.0, 10.0]" comment="[L.Red   to Gray,    Initial value: 10.0, Transition range: 10.0]"/>
         <set_value name="$_Table.{10}"  exact="[[192, 192, 192], [128, 255, 128],  0.0, 10.0]" comment="[Gray    to L.Green, Initial value:  0.0, Transition range: 10.0]"/>
         <set_value name="$_Table.{15}"  exact="[[128, 255, 128], [0,   255,   0], 10.0,  5.0]" comment="[L.Green to Green,   Initial value: 10.0, Transition range:  5.0]"/>
         <set_value name="$_Table.{30}"  exact="[[  0, 255,   0], [0,   136, 255], 15.0, 15.0]" comment="[Green   to Blue,    Initial value: 15.0, Transition range: 15.0]"/>

         <do_for_each name="$_Key" valuename="$_Value" in="$_Table">
            <do_if value="$FACTION_RELATION le $_Key">
               <do_if value="$FACTION_RELATION le 0">
                  <set_value name="$_BlendRatio" exact="(($FACTION_RELATION)f + $_Value.{3}) / $_Value.{4}"/>
               </do_if>
               <do_else>
                  <set_value name="$_BlendRatio" exact="(($FACTION_RELATION)f - $_Value.{3}) / $_Value.{4}"/>
               </do_else>
               <set_value name="$_R" exact="($_Value.{1}.{1} * (1 - $_BlendRatio) + $_Value.{2}.{1} * $_BlendRatio)i"/>
               <set_value name="$_G" exact="($_Value.{1}.{2} * (1 - $_BlendRatio) + $_Value.{2}.{2} * $_BlendRatio)i"/>
               <set_value name="$_B" exact="($_Value.{1}.{3} * (1 - $_BlendRatio) + $_Value.{2}.{3} * $_BlendRatio)i"/>
               <break/>
            </do_if>
         </do_for_each>

         <run_script name="'jp.lib.ConvertARGBtoHex'" result="$_FactionRelationColorCode">
            <param name="ALPHA" value="255"/>
            <param name="RED" value="$_R"/>
            <param name="GREEN" value="$_G"/>
            <param name="BLUE" value="$_B"/>
         </run_script>

         <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->

         <label name="END_LBL"/>
         <do_if value="$DEBUG gt 0">
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'[' + player.systemtime.{'%F - %X'} + '] ' + '~~ ' + $_DebugScriptName + '.xml ~ SCRIPT_END ~~'"/>
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~\n'"/>
         </do_if>

         <return value="$_FactionRelationColorCode"/>

      </actions>
   </attention>

   <on_abort>
   </on_abort>

</aiscript><?xml version="1.0" encoding="utf-8"?>

<aiscript name="jp.lib.IdleReturnHome" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="aiscripts.xsd">

   <order id="JP_lib_IdleReturnHome" name="{8888888, 40}" category="internal" infinite="false" allowinloop="false" canplayercancel="true">
      <params>
         <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
         <param name="IDLE_TIME"      type="internal" default="null"/>
         <param name="IDLE_MOVE_TO"   type="internal" default="null"/>
         <param name="WHERE_TO_MOVE"  type="internal" default="null"/>
         <param name="START_POSITION" type="internal" default="null"/>
         <param name="IDLE_FOLLOW"    type="internal" default="null"/>
         <param name="WHO_TO_FOLLOW"  type="internal" default="null"/>
         <param name="IDLE_DOCKING"   type="internal" default="null"/>
         <param name="FIND_STATION"   type="internal" default="null"/>
         <param name="WHERE_TO_DOCK"  type="internal" default="null"/>
         <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
         <param name="debugchance" type="internal" default="0"/>
         <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      </params>
   </order>

   <interrupts>
      <handler comment="Handler to cancel IdleReturnHome Orders, add this also to all sub orders created by IdleReturnHome">
         <conditions>
            <event_object_signalled object="this.ship" param="'Cancel_IdleReturnHome'"/>
         </conditions>
         <actions>
            <cancel_order order="this.ship.order"/>
         </actions>
      </handler>
   </interrupts>

   <init>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <set_value name="$_Ship" exact="this.ship"/>
      <set_value name="$_DefaultOrderParamRef" exact="if $_Ship.defaultorder.id == 'Assist' then $_Ship.commander.defaultorder else $_Ship.defaultorder"/>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <set_value name="global.$SL_IdleShips.{$_Ship}" exact="player.age"/>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <set_value name="$DEBUG" exact="@$_DefaultOrderParamRef.$DEBUG"/>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <do_if value="$DEBUG gt 0">
         <set_value name="$_DebugFolderName" exact="@$_DefaultOrderParamRef.$DEBUG_FOLDER_NAME"/>
         <set_value name="$_DebugScriptName" exact="'jp.lib.IdleReturnHome'"/>
         <set_value name="$_DebugFileName"   exact="$_Ship.idcode + '.' + $_DebugScriptName + '.xml.log'"/>
      </do_if>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
   </init>

   <attention min="unknown">
      <actions>

         <label name="INIT_LBL"/>
         <do_if value="$DEBUG gt 0">
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~'" append="false"/>
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'[' + player.systemtime.{'%F - %X'} + '] ' + '~~ ' + $_DebugScriptName + '.xml ~ SCRIPT_START ~~' + '\n'"/>
         </do_if>

         <substitute_text source="$_Ship.knownname" text="$_ResultName">
            <replace string="'\033#FFCEFBA1# ~ Idle\033X'" with="''"/>
         </substitute_text>
         <do_if value="$_Ship.knownname == $_ResultName">
            <set_object_name object="$_Ship" name="$_Ship.knownname + '\033#FFCEFBA1# ~ Idle\033X'"/>
         </do_if>

         <do_if value="not $IDLE_MOVE_TO and not $IDLE_FOLLOW and not $IDLE_DOCKING">
            <set_value name="$IDLE_MOVE_TO" exact="true" chance="100"/>
            <set_value name="$WHERE_TO_MOVE" exact="$START_POSITION"/>
         </do_if>

         <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->

         <set_command_action commandaction="commandaction.standingby"/>

         <label name="IDLE_MOVE_TO_LBL"/>
         <do_if value="$IDLE_MOVE_TO">
            <do_if value="$_Ship.distanceto.[$WHERE_TO_MOVE.{1}, $WHERE_TO_MOVE.{2}] gt 10km">
               <create_order id="'JP_lib_MoveToPosition'" object="$_Ship" immediate="true">
                  <param name="SECTOR"   value="$WHERE_TO_MOVE.{1}"/>
                  <param name="POSITION" value="$WHERE_TO_MOVE.{2}"/>
               </create_order>
               <wait exact="1ms"/>
            </do_if>
            <do_else>
               <wait exact="$IDLE_TIME"/>
            </do_else>
         </do_if>

         <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->

         <label name="IDLE_FOLLOW_LBL"/>
         <do_if value="$IDLE_FOLLOW">
            <do_if value="$WHO_TO_FOLLOW == null">
               <set_value name="$IDLE_MOVE_TO" exact="true"/>
               <resume label="IDLE_MOVE_TO_LBL"/>
            </do_if>
            <create_order object="$_Ship" id="'Follow'" immediate="true">
               <param name="IDLE_RETURN_HOME" value="true"/>
               <param name="target" value="$WHO_TO_FOLLOW"/>
            </create_order>
            <wait exact="1ms"/>
         </do_if>

         <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->

         <label name="IDLE_DOCKING_LBL"/>
         <do_if value="$IDLE_DOCKING">
            <do_if value="not @$WHERE_TO_DOCK.dockingallowed.{$_Ship}">
               <do_if value="$FIND_STATION">
                  <create_list name="$_FoundStations"/>
                  <find_station name="$_FoundStations" space="player.galaxy" multiple="true">
                     <match knownto="$_Ship.owner"/>
                     <match checkoperational="true"/>
                     <match_relation_to faction="$_Ship.owner" comparison="ge" relation="dock"/>
                  </find_station>
                  <run_script name="'jp.lib.SortByEstimatedTravelTime'" result="$_FoundStations">
                     <param name="LIST" value="$_FoundStations"/>
                  </run_script>
                  <do_for_each name="$_FoundStation" in="$_FoundStations">
                     <do_if value="$_FoundStation.dockingallowed.{$_Ship}">
                        <set_value name="$WHERE_TO_DOCK" exact="$_FoundStation"/>
                        <break/>
                     </do_if>
                  </do_for_each>
               </do_if>
               <do_if value="not @$WHERE_TO_DOCK.dockingallowed.{$_Ship}">
                  <set_value name="$IDLE_MOVE_TO" exact="true"/>
                  <resume label="IDLE_MOVE_TO_LBL"/>
               </do_if>
            </do_if>
            <create_order object="$_Ship" id="'DockAndWait'" immediate="true">
               <param name="IDLE_RETURN_HOME" value="true"/>
               <param name="destination" value="$WHERE_TO_DOCK"/>
               <param name="timeout" value="999h"/>
            </create_order>
            <wait exact="1ms"/>
         </do_if>

         <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->

         <label name="END_LBL"/>
         <do_if value="$DEBUG gt 0">
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'[' + player.systemtime.{'%F - %X'} + '] ' + '~~ ' + $_DebugScriptName + '.xml ~ SCRIPT_END ~~'"/>
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~\n'"/>
         </do_if>

      </actions>
   </attention>

   <on_abort>
   </on_abort>

</aiscript><?xml version="1.0" encoding="utf-8"?>

<aiscript name="jp.lib.MessageLog" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="aiscripts.xsd" version="1">

   <params>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <param name="GENERATE_TITLE"       default="true"/>
      <param name="TITLE"                default="''"/>
      <param name="TEXT"                 default="''"/>
      <param name="MESSAGE_TEXT"         default="''"/>
      <param name="LOG_TEXT"             default="''"/>
      <param name="INTERACTION_OBJECT"   default="this.ship"/>
      <param name="INTERACTION_POSITION" default="position.[0, 0, 0]"/>
      <param name="MESSAGE_POSITION"     default="1"/>
      <param name="MESSAGE_CHANCE"       default="1"/>
      <param name="LOG_CHANCE"           default="1"/>
      <param name="CATEGORY"             default="'upkeep'"/>
      <param name="INTERACTION"          default="'showonmap'"/>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <param name="debugchance" default="0"/>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
   </params>

   <init>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <set_value name="$_Ship" exact="this.ship"/>
      <set_value name="$_DefaultOrderParamRef" exact="if $_Ship.defaultorder.id == 'Assist' then $_Ship.commander.defaultorder else $_Ship.defaultorder"/>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <do_if value="$MESSAGE_TEXT == ''">
         <set_value name="$MESSAGE_TEXT" exact="$TEXT"/>
      </do_if>
      <do_if value="$LOG_TEXT == ''">
         <set_value name="$LOG_TEXT" exact="$TEXT"/>
      </do_if>
      <do_if value="$GENERATE_TITLE and $TITLE == ''">
         <set_value name="$TITLE" exact="'%1 ~ %2 [%3]'.[$_DefaultOrderParamRef.name, $_Ship.knownname, $_Ship.idcode]"/>
         <substitute_text source="$TITLE" text="$TITLE">
            <replace string="'\033#FFCEFBA1# ~ Idle\033X'"   with="''"/>
            <replace string="'\033#FFA95908##ASE-G\033X ~ '" with="''"/>
            <replace string="'\033#FFA95908##AE-S\033X ~ '"  with="''"/>
            <replace string="'\033#FFA95908##AE-G\033X ~ '"  with="''"/>
            <replace string="'\033#FFA95908##CP-S\033X ~ '"  with="''"/>
            <replace string="'\033#FFA95908##CP-G\033X ~ '"  with="''"/>
            <replace string="'\033#FFA95908##DVE-G\033X ~ '" with="''"/>
            <replace string="'\033#FFA95908##SD-S\033X ~ '"  with="''"/>
            <replace string="'\033#FFA95908##SD-G\033X ~ '"  with="''"/>
            <replace string="'\033#FFA95908##SE-S\033X ~ '"  with="''"/>
            <replace string="'\033#FFA95908##SE-G\033X ~ '"  with="''"/>
            <replace string="'\033#FFA95908##TSE-S\033X ~ '" with="''"/>
            <replace string="'\033#FFA95908##TSE-G\033X ~ '" with="''"/>
         </substitute_text>
      </do_if>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <set_value name="$SHOW_MESSAGES" exact="@$_DefaultOrderParamRef.$SHOW_MESSAGES"/>
      <set_value name="$WRITE_TO_LOG"  exact="@$_DefaultOrderParamRef.$WRITE_TO_LOG"/>
      <set_value name="$DEBUG"         exact="@$_DefaultOrderParamRef.$DEBUG"/>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <do_if value="$DEBUG gt 0">
         <set_value name="$_DebugFolderName" exact="@$_DefaultOrderParamRef.$DEBUG_FOLDER_NAME"/>
         <set_value name="$_DebugScriptName" exact="'jp.lib.MessageLog'"/>
         <set_value name="$_DebugFileName" exact="$_Ship.idcode + '.' + $_DebugScriptName + '.xml.log'"/>
      </do_if>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
   </init>

   <attention min="unknown">
      <actions>

         <label name="INIT_LBL"/>
         <do_if value="$DEBUG gt 0">
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~'" append="false"/>
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'[' + player.systemtime.{'%F - %X'} + '] ' + '~~ ' + $_DebugScriptName + '.xml ~ SCRIPT_START ~~' + '\n'"/>
         </do_if>

         <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->

         <set_value name="$_ShowMessages" exact="if $SHOW_MESSAGES ge $MESSAGE_CHANCE then 100 else 0"/>
         <set_value name="$_WriteToLog"   exact="if $WRITE_TO_LOG ge $LOG_CHANCE then 100 else 0"/>

         <show_help custom="$TITLE + '\n\n' + $MESSAGE_TEXT" position="$MESSAGE_POSITION" allowclose="true" chance="$_ShowMessages"/>

         <do_if value="$CATEGORY == 'general'">
            <do_if value="$INTERACTION == 'showonmap'">
               <write_to_logbook title="$TITLE" text="$LOG_TEXT" category="general" interaction="showonmap" object="$INTERACTION_OBJECT" chance="$_WriteToLog"/>
            </do_if>
            <do_elseif value="$INTERACTION == 'showlocationonmap'">
               <write_to_logbook title="$TITLE" text="$LOG_TEXT" category="general" interaction="showlocationonmap" object="$INTERACTION_OBJECT" position="$INTERACTION_POSITION" chance="$_WriteToLog"/>
            </do_elseif>
         </do_if>
         <do_elseif value="$CATEGORY == 'missions'">
            <do_if value="$INTERACTION == 'showonmap'">
               <write_to_logbook title="$TITLE" text="$LOG_TEXT" category="missions" interaction="showonmap" object="$INTERACTION_OBJECT" chance="$_WriteToLog"/>
            </do_if>
            <do_elseif value="$INTERACTION == 'showlocationonmap'">
               <write_to_logbook title="$TITLE" text="$LOG_TEXT" category="missions" interaction="showlocationonmap" object="$INTERACTION_OBJECT" position="$INTERACTION_POSITION" chance="$_WriteToLog"/>
            </do_elseif>
         </do_elseif>
         <do_elseif value="$CATEGORY == 'news'">
            <do_if value="$INTERACTION == 'showonmap'">
               <write_to_logbook title="$TITLE" text="$LOG_TEXT" category="news" interaction="showonmap" object="$INTERACTION_OBJECT" chance="$_WriteToLog"/>
            </do_if>
            <do_elseif value="$INTERACTION == 'showlocationonmap'">
               <write_to_logbook title="$TITLE" text="$LOG_TEXT" category="news" interaction="showlocationonmap" object="$INTERACTION_OBJECT" position="$INTERACTION_POSITION" chance="$_WriteToLog"/>
            </do_elseif>
         </do_elseif>
         <do_elseif value="$CATEGORY == 'upkeep'">
            <do_if value="$INTERACTION == 'showonmap'">
               <write_to_logbook title="$TITLE" text="$LOG_TEXT" category="upkeep" interaction="showonmap" object="$INTERACTION_OBJECT" chance="$_WriteToLog"/>
            </do_if>
            <do_elseif value="$INTERACTION == 'showlocationonmap'">
               <write_to_logbook title="$TITLE" text="$LOG_TEXT" category="upkeep" interaction="showlocationonmap" object="$INTERACTION_OBJECT" position="$INTERACTION_POSITION" chance="$_WriteToLog"/>
            </do_elseif>
         </do_elseif>
         <do_elseif value="$CATEGORY == 'alerts'">
            <do_if value="$INTERACTION == 'showonmap'">
               <write_to_logbook title="$TITLE" text="$LOG_TEXT" category="alerts" interaction="showonmap" object="$INTERACTION_OBJECT" chance="$_WriteToLog"/>
            </do_if>
            <do_elseif value="$INTERACTION == 'showlocationonmap'">
               <write_to_logbook title="$TITLE" text="$LOG_TEXT" category="alerts" interaction="showlocationonmap" object="$INTERACTION_OBJECT" position="$INTERACTION_POSITION" chance="$_WriteToLog"/>
            </do_elseif>
         </do_elseif>
         <do_elseif value="$CATEGORY == 'tips'">
            <do_if value="$INTERACTION == 'showonmap'">
               <write_to_logbook title="$TITLE" text="$LOG_TEXT" category="tips" interaction="showonmap" object="$INTERACTION_OBJECT" chance="$_WriteToLog"/>
            </do_if>
            <do_elseif value="$INTERACTION == 'showlocationonmap'">
               <write_to_logbook title="$TITLE" text="$LOG_TEXT" category="tips" interaction="showlocationonmap" object="$INTERACTION_OBJECT" position="$INTERACTION_POSITION" chance="$_WriteToLog"/>
            </do_elseif>
         </do_elseif>

         <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->

         <label name="END_LBL"/>
         <do_if value="$DEBUG gt 0">
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'[' + player.systemtime.{'%F - %X'} + '] ' + '~~ ' + $_DebugScriptName + '.xml ~ SCRIPT_END ~~'"/>
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~\n'"/>
         </do_if>

      </actions>
   </attention>

   <on_abort>
   </on_abort>

</aiscript><?xml version="1.0" encoding="utf-8"?>

<aiscript name="jp.lib.MoveThroughGate" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="aiscripts.xsd">

   <order id="JP_lib_MoveThroughGate" name="Move through Gate" category="internal" infinite="false" allowinloop="false" canplayercancel="true">
      <params>
         <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
         <param name="GATE" type="internal" default="null"/>
         <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
         <param name="debugchance" type="internal" default="0"/>
         <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      </params>
      <location object="$LOCATION.{1}" position="$LOCATION.{2}" condition="@$LOCATION.{1} != null and @$LOCATION.{2} != null"/>
      <location object="$LOCATION.{1}" condition="@$LOCATION.{1} != null"/>
   </order>

   <interrupts>
      <library>
         <actions name="CalculateRandomGateApproachOffsets">
            <set_value name="$_RandomOffsetX" min="-1000m" max="1000m" profile="bell"/>
            <set_value name="$_RandomOffsetY" min="-1000m" max="1000m" profile="bell"/>
            <set_value name="$_RandomOffsetZ" min="3000m"  max="6000m" profile="bell"/>
         </actions>
      </library>
      <handler ref="AttackHandler"/>
      <handler ref="MissileLockHandler" />
      <handler ref="ScannedHandler"/>
      <handler ref="InspectedHandler"/>
      <handler ref="FoundAbandonedHandler"/>
      <handler ref="FoundLockboxHandler"/>
      <handler ref="ResupplyHandler"/>
      <handler ref="TideHandler"/>
   </interrupts>

   <init>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <set_value name="$_Ship" exact="this.ship"/>
      <set_value name="$_DefaultOrderParamRef" exact="if $_Ship.defaultorder.id == 'Assist' then $_Ship.commander.defaultorder else $_Ship.defaultorder"/>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <set_value name="$_IsCapShip" exact="$_Ship.isclass.{[class.ship_l, class.ship_xl]}"/>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <set_value name="$DEBUG" exact="@$_DefaultOrderParamRef.$DEBUG"/>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <do_if value="$DEBUG gt 0">
         <set_value name="$_DebugFolderName" exact="@$_DefaultOrderParamRef.$DEBUG_FOLDER_NAME"/>
         <set_value name="$_DebugScriptName" exact="'jp.lib.MoveThroughGate'"/>
         <set_value name="$_DebugFileName" exact="$_Ship.idcode + '.' + $_DebugScriptName + '.xml.log'"/>
      </do_if>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
   </init>

   <attention min="unknown">
      <actions>

         <label name="INIT_LBL"/>
         <do_if value="$DEBUG gt 0">
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~'" append="false"/>
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'[' + player.systemtime.{'%F - %X'} + '] ' + '~~ ' + $_DebugScriptName + '.xml ~ SCRIPT_START ~~' + '\n'"/>
         </do_if>

         <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->

         <!-- TODO: Adjust the transition into other sectors for L/XL ships (Warp Drive)? -->

         <set_command command="command.move" param="$GATE"/>
         <set_command_action commandaction="commandaction.calculating"/>

         <!-- Determine the entry and exit gates based on the gate type. -->
         <do_if value="$GATE.isclass.gate or $GATE.isclass.highwayentrygate">
            <set_value name="$_EntryGate" exact="$GATE"/>
            <set_value name="$_ExitGate"  exact="$GATE.exit"/>
         </do_if>
         <do_elseif value="$GATE.isclass.highway">
            <set_value name="$_EntryGate" exact="$GATE.entry"/>
            <set_value name="$_ExitGate" exact="$GATE.entry.exit"/>
         </do_elseif>

         <!-- Assign the sectors and types based on the gate -->
         <set_value name="$_EntryGateSector" exact="$_EntryGate.sector"/>
         <set_value name="$_ExitGateSector"  exact="$_ExitGate.sector"/>
         <set_value name="$_IsGate"          exact="@$_EntryGate.isclass.gate and not @$_EntryGate.isaccelerator"/>
         <set_value name="$_IsAccelerator"   exact="@$_EntryGate.isclass.gate and @$_EntryGate.isaccelerator"/>
         <set_value name="$_IsSuperhighway"  exact="@$_EntryGate.isclass.highwayentrygate"/>

         <!-- Include code that calculates random offsets for the final approach position to the gate -->
         <set_value name="$_Gate" exact="$_EntryGate"/>
         <include_interrupt_actions ref="CalculateRandomGateApproachOffsets"/>

         <!-- Determine ship movement based on the type of gate and the size of the ship -->
         <do_if value="@$_IsGate and @$_IsCapShip">
            <!-- Specific behavior for capital ships and gates -->
            <set_value name="$_Radius" exact="4km"/>
            <create_list name="$_CapShipApproachPositions"/>

            <create_position name="$_EvalPosLeft" space="$_EntryGateSector" object="$_EntryGate" x="-$_Radius"/>
            <create_position name="$_EvalPosRight" space="$_EntryGateSector" object="$_EntryGate" x="$_Radius"/>

            <do_if value="$_Ship.distanceto.[$_EntryGateSector, $_EvalPosLeft] lt $_Ship.distanceto.[$_EntryGateSector, $_EvalPosRight]">
               <set_value name="$_Radius" exact="-$_Radius"/>
               <set_value name="$_AngleSteps" exact="[0, 45, 90, 135, 180]"/>
            </do_if>
            <do_else>
               <set_value name="$_Radius" exact="$_Radius"/>
               <set_value name="$_AngleSteps" exact="[0, -45, -90, -135, -180]"/>
            </do_else>

            <do_for_each name="$_Angle" in="$_AngleSteps">
               <set_value name="$_AngleRadian" exact="$_Angle * pi / 180"/>
               <create_position name="$_CirclePos" space="$_EntryGateSector" object="$_EntryGate"
                                x="$_Radius * cos($_AngleRadian) + $_Radius"
                                y="0"
                                z="$_Radius * sin($_AngleRadian) + -$_RandomOffsetZ"/>

               <append_to_list name="$_CapShipApproachPositions" exact="$_CirclePos"/>
            </do_for_each>
         </do_if>
         <do_elseif value="@$_IsSuperhighway">
            <!-- Specific behavior for superhighways -->
            <get_safe_pos result="$_EntryGateApproachPosition" sector="$_EntryGateSector" object="$_EntryGate" radius="$_Ship.size" ignored="$_Ship" x="$_RandomOffsetX" y="$_RandomOffsetY" z="-$_RandomOffsetZ"/>
         </do_elseif>
         <do_else>
            <!-- Default behavior ~ includes jump gates and accelerators -->
            <get_safe_pos result="$_EntryGateApproachPosition" sector="$_EntryGateSector" object="$_EntryGate" radius="$_Ship.size" ignored="$_Ship" x="$_RandomOffsetX" y="$_RandomOffsetY" z="$_RandomOffsetZ"/>
         </do_else>

         <!-- For capital ships, use the list of approach positions -->
         <!-- For all other ships, use the calculated approach position. -->
         <do_if value="@$_IsCapShip">
            <set_value name="$LOCATION" exact="[$_EntryGateSector, $_CapShipApproachPositions.{1}]"/>
            <run_script name="'jp.lib.MoveToPosition'">
               <param name="SECTOR" value="$_EntryGateSector"/>
               <param name="POSITIONS" value="$_CapShipApproachPositions"/>
               <param name="FORCE_POSITION" value="true"/>
               <param name="FINISH_ON_APPROACH" value="true"/>
            </run_script>
         </do_if>
         <do_else>
            <set_value name="$LOCATION" exact="[$_EntryGateSector, $_EntryGateApproachPosition]"/>
            <run_script name="'jp.lib.MoveToPosition'">
               <param name="SECTOR" value="$_EntryGateSector"/>
               <param name="POSITION" value="$_EntryGateApproachPosition"/>
               <param name="FORCE_POSITION" value="true"/>
               <param name="FINISH_ON_APPROACH" value="true"/>
            </run_script>
         </do_else>

         <set_value name="$LOCATION" exact="[$_ExitGate, null]"/>
         <!-- Execute the transition through the gate based on the ship size. -->
         <do_if value="@$_IsGate or @$_IsAccelerator">
            <do_if value="@$_IsCapShip">
               <move_gate object="$_Ship" gate="$_EntryGate">
                  <interrupt>
                     <conditions>
                        <event_object_changed_sector object="$_Ship"/>
                     </conditions>
                  </interrupt>
               </move_gate>
            </do_if>
            <do_else>
               <move_to object="$_Ship" destination="$_ExitGate">
                  <interrupt>
                     <conditions>
                        <event_object_changed_sector object="$_Ship"/>
                     </conditions>
                  </interrupt>
               </move_to>
            </do_else>
            <stop_moving object="$_Ship" immediate="true"/>
            <warp object="$_Ship" sector="$_ExitGateSector">
               <position space="$_ExitGateSector" object="$_ExitGate" value="position.[$_RandomOffsetX, $_RandomOffsetY, 1km + $_Ship.length / 2]"/>
               <rotation pitch="$_ExitGate.rotation.pitch" yaw="$_ExitGate.rotation.yaw" roll="$_ExitGate.rotation.roll"/>
            </warp>
         </do_if>

         <!-- Transition through the Superhighway. -->
         <do_if value="@$_IsSuperhighway">
            <move_to object="$_Ship" destination="$_ExitGate">
               <interrupt>
                  <conditions>
                     <event_object_changed_zone object="$_Ship"/>
                     <check_value value="event.param.isclass.highway"/>
                  </conditions>
               </interrupt>
            </move_to>
            <wait exact="60s">
               <interrupt>
                  <conditions>
                     <event_object_changed_sector object="$_Ship"/>
                  </conditions>
               </interrupt>
            </wait>
         </do_if>

         <!-- Include code that calculates random offsets for the final position for clearing the gate -->
         <set_value name="$_Gate" exact="$_ExitGate"/>
         <include_interrupt_actions ref="CalculateRandomGateApproachOffsets"/>

         <!-- After the transition, move the ship away from the exit gate to a safe position. -->
         <remove_value name="$_MaxOffset"/>
         <get_safe_pos result="$_ExitGateApproachPosition" sector="$_ExitGateSector" object="$_ExitGate" radius="$_Ship.size" ignored="$_Ship"  x="$_RandomOffsetX" y="$_RandomOffsetY" z="$_RandomOffsetZ"/>
         <set_value name="$LOCATION" exact="[$_ExitGateSector, $_ExitGateApproachPosition]"/>
         <run_script name="'jp.lib.MoveToPosition'">
            <param name="SECTOR" value="$_ExitGateSector"/>
            <param name="POSITION" value="$_ExitGateApproachPosition"/>
            <param name="FORCE_POSITION" value="true"/>
            <param name="FINISH_ON_APPROACH" value="true"/>
         </run_script>

         <!--~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~-->

         <label name="END_LBL"/>
         <do_if value="$DEBUG gt 0">
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'[' + player.systemtime.{'%F - %X'} + '] ' + '~~ ' + $_DebugScriptName + '.xml ~ SCRIPT_END ~~'"/>
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~\n'"/>
         </do_if>

      </actions>
   </attention>

   <on_abort>
   </on_abort>

</aiscript><?xml version="1.0" encoding="utf-8"?>

<aiscript name="jp.lib.MoveToObject" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="aiscripts.xsd">

   <order id="JP_lib_MoveToObject" name="{8888888, 43}" category="internal" infinite="false" allowinloop="false" canplayercancel="true">
      <params>
         <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
         <!--DISTANCE_TO_OBJECT - used if $POSITION_SPACE is of class object
             POSITION_SPACE - 'sector_space', 'object_space', any object
             ROTATION_SPACE - 'sector_space', 'object_space', any object
             ROTATION_ORIENTATION - 'align', 'look_at', 'look_away', 'align_left', 'align_right'
             SAFE_POS_DIRECTION - 'up', 'down', 'left', 'right', 'forward', 'backward' -->
         <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
         <param name="OBJECT"                   type="internal" default="null"/>
         <param name="POSITION_SPACE"           type="internal" default="'object_space'"/>
         <param name="POSITION_OFFSET"          type="internal" default="position.[0, 0, 0]"/>
         <param name="DISTANCE_TO_OBJECT"       type="internal" default="10m"/>
         <param name="ROTATION_SPACE"           type="internal" default="'object_space'"/>
         <param name="ROTATION_ORIENTATION"     type="internal" default="'look_at'"/>
         <param name="FORCE_POSITION"           type="internal" default="true"/>
         <param name="FORCE_ROTATION"           type="internal" default="true"/>
         <param name="GET_SAFE_POS"             type="internal" default="false"/>
         <param name="SAFE_POS_DIRECTION"       type="internal" default="'up'"/>
         <param name="SAFE_POS_OFFSET"          type="internal" default="position.[0, 0, 0]"/>
         <param name="USE_LOCAL_HIGHWAY"        type="internal" default="this.ship.canenterhighway"/>
         <param name="USE_TRAVEL_DRIVE"         type="internal" default="true"/>
         <param name="FINISH_ON_APPROACH"       type="internal" default="false"/>
         <param name="SKIP_SECTOR_CHECK"        type="internal" default="false"/>
         <param name="IGNORE_DANGEROUS_REGIONS" type="internal" default="false"/>
         <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
         <param name="SECTOR"   type="internal" default="null"/>
         <param name="POSITION" type="internal" default="null"/>
         <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
         <param name="debugchance" type="internal" default="0"/>
         <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      </params>
      <location object="$SECTOR" position="$POSITION" condition="@$SECTOR != null and @$POSITION != null"/>
      <location object="$SECTOR" condition="@$SECTOR != null"/>
   </order>

   <interrupts>
      <handler>
         <conditions>
            <event_object_signalled object="this.ship" param="'MOVE_TO_OBJECT_INTERRUPT'"/>
         </conditions>
         <actions>
            <abort_called_scripts resume="FINISH_LBL"/>
         </actions>
      </handler>
      <handler ref="AttackHandler"/>
      <handler ref="MissileLockHandler" />
      <handler ref="ScannedHandler"/>
      <handler ref="InspectedHandler"/>
      <handler ref="FoundAbandonedHandler"/>
      <handler ref="FoundLockboxHandler"/>
      <handler ref="ResupplyHandler"/>
      <handler ref="TideHandler"/>
   </interrupts>

   <init>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <set_value name="$_Ship" exact="this.ship"/>
      <set_value name="$_DefaultOrderParamRef" exact="if $_Ship.defaultorder.id == 'Assist' then $_Ship.commander.defaultorder else $_Ship.defaultorder"/>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <set_value name="$DEBUG" exact="@$_DefaultOrderParamRef.$DEBUG"/>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <do_if value="$DEBUG gt 0">
         <set_value name="$_DebugFolderName" exact="@$_DefaultOrderParamRef.$DEBUG_FOLDER_NAME"/>
         <set_value name="$_DebugScriptName" exact="'jp.lib.MoveToObject'"/>
         <set_value name="$_DebugFileName" exact="$_Ship.idcode + '.' + $_DebugScriptName + '.xml.log'"/>
      </do_if>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
   </init>

   <attention min="unknown">
      <actions>

         <label name="INIT_LBL"/>
         <do_if value="$DEBUG gt 0">
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~'" append="false"/>
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'[' + player.systemtime.{'%F - %X'} + '] ' + '~~ ' + $_DebugScriptName + '.xml ~ SCRIPT_START ~~' + '\n'"/>
         </do_if>

         <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->

         <set_command command="command.move" param="$OBJECT"/>
         <set_command_action commandaction="commandaction.calculating"/>

         <set_value name="$SECTOR" exact="$OBJECT.sector"/>
         <do_if value="@$OBJECT.sector == null">
            <do_if value="$OBJECT.isclass.highway">
               <set_value name="$SECTOR" exact="$OBJECT.origin.sector"/>
            </do_if>
         </do_if>

         <do_if value="not $SKIP_SECTOR_CHECK and $_Ship.sector != $SECTOR">
            <create_order object="$_Ship" id="'JP_lib_MoveToSector'" immediate="true">
               <param name="SECTOR" value="$SECTOR"/>
            </create_order>
            <wait exact="1ms"/>
         </do_if>

         <do_if value="$GET_SAFE_POS">
            <do_if value="@$POSITION_SPACE == 'object_space'">
               <get_safe_pos result="$POSITION" sector="$SECTOR" object="$OBJECT" radius="$_Ship.size" ignored="$_Ship" direction="$SAFE_POS_DIRECTION"
                             x="$SAFE_POS_OFFSET.x" y="$SAFE_POS_OFFSET.y" z="$SAFE_POS_OFFSET.z"/>
            </do_if>
            <do_elseif value="@$POSITION_SPACE == 'sector_space'">
               <create_position name="$POSITION" space="$SECTOR" object="$OBJECT"/>
               <get_safe_pos result="$POSITION" sector="$SECTOR" object="$SECTOR" value="$POSITION" radius="$_Ship.size" ignored="$_Ship" direction="$SAFE_POS_DIRECTION"
                             x="$SAFE_POS_OFFSET.x" y="$SAFE_POS_OFFSET.y" z="$SAFE_POS_OFFSET.z"/>
            </do_elseif>
         </do_if>
         <do_else>
            <!-- Create a new position by applying $POSITION_OFFSET to either object_space or sector_space -->
            <do_if value="@$POSITION_SPACE == 'object_space'">
               <create_position name="$POSITION" space="$SECTOR" object="$OBJECT" x="$POSITION_OFFSET.x" y="$POSITION_OFFSET.y" z="$POSITION_OFFSET.z"/>
            </do_if>
            <do_elseif value="@$POSITION_SPACE == 'sector_space'">
               <create_position name="$POSITION" space="$SECTOR" object="$OBJECT"/>
               <create_position name="$POSITION" space="$SECTOR" object="$SECTOR" value="$POSITION" x="$POSITION_OFFSET.x" y="$POSITION_OFFSET.y" z="$POSITION_OFFSET.z"/>
            </do_elseif>
            <!-- If $POSITION_SPACE is an object, create a position towards it -->
            <do_elseif value="@$POSITION_SPACE.isclass.object">
               <create_position name="$_DirectionObjectPos" space="$SECTOR" object="$POSITION_SPACE"/>
               <create_position name="$_ObjectPos" space="$SECTOR" object="$OBJECT"/>
               <create_orientation name="$DIRECTION" orientation="look_at" refposition="$_DirectionObjectPos">
                  <position space="$SECTOR" value="$_ObjectPos"/>
               </create_orientation>
               <create_position name="$POSITION" space="$SECTOR" value="$_ObjectPos"
                                x="$DISTANCE_TO_OBJECT * sin($DIRECTION.yaw)"
                                y="$DISTANCE_TO_OBJECT * sin($DIRECTION.pitch)"
                                z="$DISTANCE_TO_OBJECT * cos($DIRECTION.yaw)"/>
            </do_elseif>
         </do_else>

         <!-- If $ROTATION_SPACE is an object, create a rotation towards it -->
         <do_if value="@$ROTATION_SPACE.isclass.object">
            <create_position name="$_DirectionObjectPos" space="$SECTOR" object="$ROTATION_SPACE"/>
            <create_position name="$_ObjectPos" space="$SECTOR" object="$OBJECT"/>
            <create_orientation name="$ROTATION" orientation="look_at" refposition="$_ObjectPos">
               <position space="$SECTOR" value="$_DirectionObjectPos"/>
            </create_orientation>
         </do_if>
         <!-- If $ROTATION_SPACE is 'object_space' create a rotation that depends on $ROTATION_ORIENTATION of the $OBJECT -->
         <do_elseif value="@$ROTATION_SPACE == 'object_space'">
            <create_position name="$_ObjectPos" space="$SECTOR" object="$OBJECT"/>
            <do_if value="$ROTATION_ORIENTATION == 'look_at'">
               <create_orientation name="$ROTATION" orientation="look_away" refposition="$POSITION">
                  <position space="$SECTOR" value="$_ObjectPos"/>
               </create_orientation>
            </do_if>
            <do_elseif value="$ROTATION_ORIENTATION == 'look_away'">
               <create_orientation name="$ROTATION" orientation="look_at" refposition="$POSITION">
                  <position space="$SECTOR" value="$_ObjectPos"/>
               </create_orientation>
            </do_elseif>
            <do_elseif value="$ROTATION_ORIENTATION == 'align_left'">
               <create_orientation name="$ROTATION" orientation="align_right" refposition="$POSITION">
                  <position space="$SECTOR" value="$_ObjectPos"/>
               </create_orientation>
            </do_elseif>
            <do_elseif value="$ROTATION_ORIENTATION == 'align_right'">
               <create_orientation name="$ROTATION" orientation="align_left" refposition="$POSITION">
                  <position space="$SECTOR" value="$_ObjectPos"/>
               </create_orientation>
            </do_elseif>
            <do_else>
               <create_rotation name="$ROTATION" value="$OBJECT.rotation"/>
            </do_else>
         </do_elseif>
         <do_else>
            <create_rotation name="$ROTATION" value="$_Ship.rotation"/>
         </do_else>

         <set_value name="this.$LOCATION" exact="[$SECTOR, $POSITION]"/>

         <set_command command="command.move" param="$OBJECT"/>
         <run_script name="'jp.lib.MoveToPosition'">
            <param name="SECTOR"                   value="$SECTOR"/>
            <param name="POSITION"                 value="$POSITION"/>
            <param name="ROTATION"                 value="$ROTATION"/>
            <param name="USE_LOCAL_HIGHWAY"        value="$USE_LOCAL_HIGHWAY"/>
            <param name="USE_TRAVEL_DRIVE"         value="$USE_TRAVEL_DRIVE"/>
            <param name="FINISH_ON_APPROACH"       value="$FINISH_ON_APPROACH"/>
            <param name="FORCE_POSITION"           value="$FORCE_POSITION"/>
            <param name="FORCE_ROTATION"           value="$FORCE_ROTATION"/>
            <param name="IGNORE_DANGEROUS_REGIONS" value="$IGNORE_DANGEROUS_REGIONS"/>
         </run_script>

         <label name="FINISH_LBL"/>
         <stop_moving object="$_Ship" immediate="true"/>
         <stop_boost object="$_Ship"/>

         <!--~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~-->

         <label name="END_LBL"/>
         <do_if value="$DEBUG gt 0">
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'[' + player.systemtime.{'%F - %X'} + '] ' + '~~ ' + $_DebugScriptName + '.xml ~ SCRIPT_END ~~'"/>
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~\n'"/>
         </do_if>

      </actions>
   </attention>

   <on_abort>
      <stop_moving object="$_Ship" immediate="true"/>
      <stop_boost object="$_Ship"/>
   </on_abort>

</aiscript><?xml version="1.0" encoding="utf-8"?>

<aiscript name="jp.lib.MoveToPosition" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="aiscripts.xsd">

   <order id="JP_lib_MoveToPosition" name="{8888888, 42}" category="internal" infinite="false" allowinloop="false" canplayercancel="true">
      <params>
         <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
         <param name="SECTOR"                   type="internal" default="this.ship.sector"/>
         <param name="POSITION"                 type="internal" default="position.[0, 0, 0]" comment="In same Sector and in Sector coordinates"/>
         <param name="POSITIONS"                type="internal" default="[]"                 comment="In same Sector and in Sector coordinates"/>
         <param name="POSITIONS_REVERSED"       type="internal" default="false"/>
         <param name="ROTATION"                 type="internal" default="null"/>
         <param name="FORCE_POSITION"           type="internal" default="true"/>
         <param name="FORCE_ROTATION"           type="internal" default="false"/>
         <param name="USE_LOCAL_HIGHWAY"        type="internal" default="this.ship.canenterhighway"/>
         <param name="USE_TRAVEL_DRIVE"         type="internal" default="true"/>
         <param name="FINISH_ON_APPROACH"       type="internal" default="true"/>
         <param name="SKIP_SECTOR_CHECK"        type="internal" default="false"/>
         <param name="IGNORE_DANGEROUS_REGIONS" type="internal" default="false"/>
         <param name="IGNORE_SAFE_POS_CHECKS"   type="internal" default="false"/>
         <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
         <param name="debugchance" type="internal" default="0"/>
         <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      </params>
      <location object="$SECTOR" position="$POSITION" condition="@$SECTOR != null and @$POSITION != null"/>
      <location object="$SECTOR" condition="@$SECTOR != null"/>
   </order>

   <interrupts>
      <handler>
         <conditions>
            <event_object_signalled object="this.ship" param="'MOVE_TO_POSITION_INTERRUPT'"/>
         </conditions>
         <actions>
            <abort_called_scripts resume="FINISH_LBL"/>
         </actions>
      </handler>
      <handler ref="AttackHandler"/>
      <handler ref="MissileLockHandler" />
      <handler ref="ScannedHandler"/>
      <handler ref="InspectedHandler"/>
      <handler ref="FoundAbandonedHandler"/>
      <handler ref="FoundLockboxHandler"/>
      <handler ref="ResupplyHandler"/>
      <handler ref="TideHandler"/>
   </interrupts>

   <init>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <set_value name="$_Ship" exact="this.ship"/>
      <set_value name="$_DefaultOrderParamRef" exact="if $_Ship.defaultorder.id == 'Assist' then $_Ship.commander.defaultorder else $_Ship.defaultorder"/>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <do_if value="$POSITIONS.count == 0">
         <append_to_list name="$POSITIONS" exact="$POSITION"/>
      </do_if>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <set_value name="$DEBUG" exact="@$_DefaultOrderParamRef.$DEBUG"/>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <do_if value="$DEBUG gt 0">
         <set_value name="$_DebugFolderName" exact="@$_DefaultOrderParamRef.$DEBUG_FOLDER_NAME"/>
         <set_value name="$_DebugScriptName" exact="'jp.lib.MoveToPosition'"/>
         <set_value name="$_DebugFileName" exact="$_Ship.idcode + '.' + $_DebugScriptName + '.xml.log'"/>
      </do_if>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
   </init>

   <attention min="unknown">
      <actions>

         <label name="INIT_LBL"/>
         <do_if value="$DEBUG gt 0">
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~'" append="false"/>
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'[' + player.systemtime.{'%F - %X'} + '] ' + '~~ ' + $_DebugScriptName + '.xml ~ SCRIPT_START ~~' + '\n'"/>
         </do_if>

         <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->

         <set_command_action commandaction="commandaction.flying"/>

         <do_if value="not $SKIP_SECTOR_CHECK and $_Ship.sector != $SECTOR">
            <create_order object="$_Ship" id="'JP_lib_MoveToSector'" immediate="true">
               <param name="SECTOR" value="$SECTOR"/>
            </create_order>
            <wait exact="1ms"/>
         </do_if>

         <do_if value="$POSITIONS_REVERSED">
            <create_list name="$_TempPositions"/>
            <do_for_each name="$_Pos" in="$POSITIONS" reverse="true">
               <append_to_list name="$_TempPositions" exact="$_Pos"/>
            </do_for_each>
            <clear_list list="$POSITIONS"/>
            <append_list_elements name="$POSITIONS" other="$_TempPositions"/>
            <remove_value name="$_TempPositions"/>
         </do_if>

         <do_for_each name="$POSITION" in="$POSITIONS">

            <!-- Long distance travel -->
            <get_zone_at_position name="$_PositionZone" sector="$SECTOR" value="$POSITION"/>
            <do_if value="$_Ship.zone != $_PositionZone">
               <get_safe_pos result="$POSITION" sector="$SECTOR" value="$POSITION" radius="$_Ship.size" ignored="$_Ship" ignoredangerousregions="$IGNORE_DANGEROUS_REGIONS" comment="Make sure $POSITION is still safe." chance="if not $IGNORE_SAFE_POS_CHECKS then 100 else 0"/>
               <set_value name="this.$LOCATION" exact="[$SECTOR, $POSITION]"/>
               <move_to object="$_Ship" destination="$SECTOR" forceposition="false" finishonapproach="true" uselocalhighways="$USE_LOCAL_HIGHWAY" travel="$USE_TRAVEL_DRIVE">
                  <position space="$SECTOR" object="$SECTOR" value="$POSITION"/>
                  <interrupt>
                     <conditions>
                        <event_object_changed_zone object="$_Ship"/>
                        <check_value value="$_Ship.zone == $_PositionZone"/>
                     </conditions>
                  </interrupt>
               </move_to>
            </do_if>

            <!-- Short distance travel -->
            <get_safe_pos result="$POSITION" sector="$SECTOR" value="$POSITION" radius="$_Ship.size" ignored="$_Ship" ignoredangerousregions="$IGNORE_DANGEROUS_REGIONS" comment="Make sure $POSITION is still safe." chance="if not $IGNORE_SAFE_POS_CHECKS then 100 else 0"/>
            <set_value name="this.$LOCATION" exact="[$SECTOR, $POSITION]"/>
            <do_if value="@$ROTATION == null">
               <move_to object="$_Ship" destination="$SECTOR" forceposition="$FORCE_POSITION" finishonapproach="$FINISH_ON_APPROACH" uselocalhighways="$USE_LOCAL_HIGHWAY" travel="$USE_TRAVEL_DRIVE">
                  <position space="$SECTOR" object="$SECTOR" value="$POSITION"/>
               </move_to>
            </do_if>
            <do_else>
               <move_to object="$_Ship" destination="$SECTOR" forceposition="$FORCE_POSITION" forcerotation="$FORCE_ROTATION" finishonapproach="$FINISH_ON_APPROACH" uselocalhighways="$USE_LOCAL_HIGHWAY" travel="$USE_TRAVEL_DRIVE">
                  <position space="$SECTOR" object="$SECTOR" value="$POSITION"/>
                  <rotation value="$ROTATION"/>
               </move_to>
            </do_else>

         </do_for_each>

         <label name="FINISH_LBL"/>
         <stop_moving object="$_Ship" immediate="true"/>
         <stop_boost object="$_Ship"/>

         <!--~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~-->

         <label name="END_LBL"/>
         <do_if value="$DEBUG gt 0">
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'[' + player.systemtime.{'%F - %X'} + '] ' + '~~ ' + $_DebugScriptName + '.xml ~ SCRIPT_END ~~'"/>
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~\n'"/>
         </do_if>

      </actions>
   </attention>

   <on_abort>
      <stop_moving object="$_Ship" immediate="true"/>
      <stop_boost object="$_Ship"/>
   </on_abort>

</aiscript><?xml version="1.0" encoding="utf-8"?>

<aiscript name="jp.lib.MoveToSector" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="aiscripts.xsd">

   <order id="JP_lib_MoveToSector" name="{8888888, 41}" category="internal" infinite="false" allowinloop="false" canplayercancel="true">
      <params>
         <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
         <param name="SECTOR"            type="internal" default="null"/>
         <param name="POSITION"          type="internal" default="null"/>
         <param name="USE_LOCAL_HIGHWAY" type="internal" default="this.ship.canenterhighway"/>
         <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
         <param name="debugchance" type="internal" default="0"/>
         <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      </params>
      <location object="$SECTOR" position="$POSITION" condition="$SECTOR != null and $POSITION != null"/>
      <location object="$SECTOR" condition="$SECTOR != null"/>
   </order>

   <interrupts>
      <handler ref="AttackHandler"/>
      <handler ref="MissileLockHandler" />
      <handler ref="ScannedHandler"/>
      <handler ref="InspectedHandler"/>
      <handler ref="FoundAbandonedHandler"/>
      <handler ref="FoundLockboxHandler"/>
      <handler ref="ResupplyHandler"/>
      <handler ref="TideHandler"/>
   </interrupts>

   <init>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <set_value name="$_Ship" exact="this.ship"/>
      <set_value name="$_DefaultOrderParamRef" exact="if $_Ship.defaultorder.id == 'Assist' then $_Ship.commander.defaultorder else $_Ship.defaultorder"/>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <set_value name="$_IsCapShip" exact="$_Ship.isclass.{[class.ship_l, class.ship_xl]}"/>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <set_value name="$DEBUG" exact="@$_DefaultOrderParamRef.$DEBUG"/>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <do_if value="$DEBUG gt 0">
         <set_value name="$_DebugFolderName" exact="@$_DefaultOrderParamRef.$DEBUG_FOLDER_NAME"/>
         <set_value name="$_DebugScriptName" exact="'jp.lib.MoveToSector'"/>
         <set_value name="$_DebugFileName" exact="$_Ship.idcode + '.' + $_DebugScriptName + '.xml.log'"/>
      </do_if>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
   </init>

   <attention min="unknown">
      <actions>

         <label name="INIT_LBL"/>
         <do_if value="$DEBUG gt 0">
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~'" append="false"/>
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'[' + player.systemtime.{'%F - %X'} + '] ' + '~~ ' + $_DebugScriptName + '.xml ~ SCRIPT_START ~~' + '\n'"/>
         </do_if>

         <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->

         <!-- TODO: Implement a blacklist usage that is stricter than the current one. -->

         <set_command command="command.move" param="$SECTOR"/>
         <set_command_action commandaction="commandaction.calculating"/>

         <include_interrupt_actions ref="GetBlacklistgroup"/>

         <!-- While ship isn't in the target sector, continue finding the path -->
         <do_while value="$_Ship.sector != $SECTOR">
            <wait exact="1ms"/>

            <!-- Get the global path to the target sector by using the associated blacklist group -->
            <get_global_path component="$_PathComponents" refobject="$_Ship" uselocalhighways="$USE_LOCAL_HIGHWAY" useblacklist="$blacklistgroup" multiple="true">
               <start object="$_Ship"/>
               <end object="$SECTOR"/>
            </get_global_path>

            <!-- If there is no path, we try again without using the blacklist,
                 and if that fails, the sector is unreachable. -->
            <do_if value="$_PathComponents.count lt 2">
               <get_global_path component="$_PathComponents" refobject="$_Ship" uselocalhighways="$USE_LOCAL_HIGHWAY" multiple="true">
                  <start object="$_Ship"/>
                  <end object="$SECTOR"/>
               </get_global_path>
            </do_if>

            <!-- Iterate through each path component -->
            <do_for_each name="$_PathComponent" in="$_PathComponents" counter="$_it">

               <set_value name="$_PathComponentSector" exact="$_PathComponent.sector"/>
               <do_if value="@$_PathComponentSector == null">
                  <do_if value="@$_PathComponent.issuperhighway">
                     <set_value name="$_PathComponentSector" exact="$_PathComponent.origin.sector"/>
                  </do_if>
               </do_if>

               <!-- Handle the special case of the Ring-Highway transition -->
               <do_if value="$_PathComponent.isclass.highway and @$_PathComponent.exitjumpgate != null">
                  <do_if value="not $_Ship.zone.isclass.highway">
                     <set_flight_control_model object="$_Ship" flightcontrolmodel="flightcontrolmodel.spline"/>
                     <move_to object="$_Ship" destination="$SECTOR" uselocalhighways="true" travel="true" finishonapproach="true">
                        <interrupt>
                           <conditions>
                              <event_object_changed_zone object="$_Ship"/>
                              <check_value value="$_Ship.zone.isclass.highway"/>
                           </conditions>
                        </interrupt>
                     </move_to>
                  </do_if>
                  <do_if value="@$_PathComponents.indexof.{@$_PathComponent.exitjumpgate}">
                     <wait exact="600s">
                        <interrupt>
                           <conditions>
                              <event_object_changed_sector object="$_Ship"/>
                           </conditions>
                        </interrupt>
                     </wait>
                     <set_to_default_flight_control_model object="$_Ship"/>
                     <break/>
                  </do_if>
               </do_if>

               <!-- Handle other gate transitions -->
               <set_to_default_flight_control_model object="$_Ship"/>
               <do_if value="(@$_PathComponent.isclass.gate or @$_PathComponent.issuperhighway) and
                              $_PathComponentSector == $_Ship.sector">
                  <run_script name="'jp.lib.MoveThroughGate'">
                     <param name="GATE" value="$_PathComponent"/>
                  </run_script>
                  <break/>
               </do_if>

            </do_for_each>

         </do_while>

         <!-- Leave the highway if in target sector -->
         <do_if value="$_Ship.zone.isclass.highway">
            <set_to_default_flight_control_model object="$_Ship"/>
            <set_value name="$_RandomX" min="-2000m" max="2000m" profile="bell"/>
            <create_position name="$_Position" space="$SECTOR" object="$_Ship" x="$_RandomX" y="2500m" z="10000m"/>
            <move_to object="$_Ship" destination="$SECTOR" forceposition="true" finishonapproach="true">
               <position space="$SECTOR" object="$SECTOR" value="$_Position"/>
            </move_to>
         </do_if>

         <!-- Move to a specific position if provided -->
         <do_if value="@$POSITION != null">
            <run_script name="'jp.lib.MoveToPosition'">
               <param name="SECTOR" value="$SECTOR"/>
               <param name="POSITION" value="$POSITION"/>
               <param name="SKIP_SECTOR_CHECK" value="true"/>
            </run_script>
         </do_if>

         <!--~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~-->

         <label name="END_LBL"/>
         <do_if value="$DEBUG gt 0">
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'[' + player.systemtime.{'%F - %X'} + '] ' + '~~ ' + $_DebugScriptName + '.xml ~ SCRIPT_END ~~'"/>
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~\n'"/>
         </do_if>

      </actions>
   </attention>

   <on_abort>
      <set_to_default_flight_control_model object="this.ship"/>
   </on_abort>

</aiscript><?xml version="1.0" encoding="utf-8"?>

<aiscript name="jp.lib.RestockDeployables" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="aiscripts.xsd">

   <params>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <!-- Table with amounts mapped to deployables macros -->
      <!-- Amounts are what we want at the end of the restock.. not the amount we need to change -->
      <!-- If we go over the capacity of the ship, the $DEPLOYABLE_TABLE will be capped to the capacity -->
      <param name="DEPLOYABLE_TABLE" default="table[]"/>
      <param name="FORCE_RERSTOCK" default="false"/>
      <param name="PURCHASE_THRESHOLD" default="100000Cr"/>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <param name="debugchance" default="0"/>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
   </params>

   <init>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <set_value name="$_Ship" exact="this.ship"/>
      <set_value name="$_DefaultOrderParamRef" exact="if $_Ship.defaultorder.id == 'Assist' then $_Ship.commander.defaultorder else $_Ship.defaultorder"/>
      <set_value name="$_Result" exact="'Failed'"/>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <set_value name="$_DeployablesCapacity" exact="$_Ship.ammostorage.deployable.capacity"/>
      <set_value name="$_DeployablesFreeStorage" exact="$_Ship.ammostorage.deployable.free"/>
      <set_value name="$_DeployablesToBuy" exact="table[]"/>
      <set_value name="$_DeployablesToBuyAmount" exact="0"/>
      <set_value name="$_DeployablesToSell" exact="table[]"/>
      <set_value name="$_DeployablesToSellAmount" exact="0"/>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <set_value name="$RESTOCK_TITLE" exact="'%1 ~ %2 [%3]'.[$_DefaultOrderParamRef.name, $_Ship.knownname, $_Ship.idcode]"/>
      <substitute_text source="$RESTOCK_TITLE" text="$RESTOCK_TITLE">
         <replace string="'\033#FFCEFBA1# ~ Idle\033X'"   with="''"/>
         <replace string="'\033#FFA95908##ASE-G\033X ~ '" with="''"/>
         <replace string="'\033#FFA95908##AE-S\033X ~ '"  with="''"/>
         <replace string="'\033#FFA95908##AE-G\033X ~ '"  with="''"/>
         <replace string="'\033#FFA95908##CP-S\033X ~ '"  with="''"/>
         <replace string="'\033#FFA95908##CP-G\033X ~ '"  with="''"/>
         <replace string="'\033#FFA95908##DVE-G\033X ~ '" with="''"/>
         <replace string="'\033#FFA95908##SD-S\033X ~ '"  with="''"/>
         <replace string="'\033#FFA95908##SD-G\033X ~ '"  with="''"/>
         <replace string="'\033#FFA95908##SE-S\033X ~ '"  with="''"/>
         <replace string="'\033#FFA95908##SE-G\033X ~ '"  with="''"/>
         <replace string="'\033#FFA95908##TSE-S\033X ~ '" with="''"/>
         <replace string="'\033#FFA95908##TSE-G\033X ~ '" with="''"/>
      </substitute_text>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <set_value name="$SHOW_MESSAGES" exact="@$_DefaultOrderParamRef.$SHOW_MESSAGES"/>
      <set_value name="$WRITE_TO_LOG" exact="@$_DefaultOrderParamRef.$WRITE_TO_LOG"/>
      <set_value name="$DEBUG" exact="@$_DefaultOrderParamRef.$DEBUG"/>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <do_if value="$DEBUG gt 0">
         <set_value name="$_DebugFolderName" exact="@$_DefaultOrderParamRef.$DEBUG_FOLDER_NAME"/>
         <set_value name="$_DebugScriptName" exact="'jp.lib.RestockDeployables'"/>
         <set_value name="$_DebugFileName" exact="$_Ship.idcode + '.' + $_DebugScriptName + '.xml.log'"/>
      </do_if>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
   </init>

   <attention min="unknown">
      <actions>

         <label name="INIT_LBL"/>
         <do_if value="$DEBUG gt 0">
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~'" append="false"/>
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'[' + player.systemtime.{'%F - %X'} + '] ' + '~~ ' + $_DebugScriptName + '.xml ~ SCRIPT_START ~~' + '\n'"/>
         </do_if>

         <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->

         <set_command command="command.resupply"/>
         <set_command_action commandaction="commandaction.calculating"/>

         <!-- Calculate the total amount of storage needed for the deployables inside the $DEPLOYABLE_TABLE -->
         <set_value name="$_TotalStorageNeeded" exact="0"/>
         <do_for_each name="$_DeployableMacro" valuename="$_DeployableAmount" in="$DEPLOYABLE_TABLE">
            <set_value name="$_TotalStorageNeeded" exact="$_DeployableAmount" operation="add"/>
         </do_for_each>

         <!-- If there are more deployables in the $DEPLOYABLE_TABLE than the ship can hold,
              we need to cap the $DEPLOYABLE_TABLE to the capacity of the ship. -->
         <do_if value="$_TotalStorageNeeded gt $_DeployablesCapacity">
            <do_while value="$_TotalStorageNeeded gt $_DeployablesCapacity">
               <wait exact="1ms" comment="In case of an endless loop, the game will freeze if there is no wait."/>
               <set_value name="$_HighestAmount" exact="0"/>
               <set_value name="$_HighestMacro" exact="null"/>
               <do_for_each name="$_DeployableMacro" valuename="$_DeployableAmount" in="$DEPLOYABLE_TABLE">
                  <do_if value="$_DeployableAmount gt $_HighestAmount">
                     <set_value name="$_HighestAmount" exact="$_DeployableAmount"/>
                     <set_value name="$_HighestMacro" exact="$_DeployableMacro"/>
                  </do_if>
               </do_for_each>
               <set_value name="$DEPLOYABLE_TABLE.{$_HighestMacro}" exact="1" operation="subtract"/>
               <set_value name="$_TotalStorageNeeded"               exact="1" operation="subtract"/>
            </do_while>
         </do_if>

         <!-- Populate the $_DeployablesToBuy and $_DeployablesToSell tables with
              the macros and amounts of the deployables we need to buy and sell. -->
         <do_for_each name="$_DeployableMacro" valuename="$_DeployableAmount" in="$DEPLOYABLE_TABLE">
            <do_if value="$_DeployableAmount gt $_Ship.ammostorage.{$_DeployableMacro}.count">
               <set_value name="$_DeployablesToBuy.{$_DeployableMacro}" exact="$_DeployableAmount - $_Ship.ammostorage.{$_DeployableMacro}.count" operation="add"/>
               <set_value name="$_DeployablesToBuyAmount"               exact="$_DeployableAmount - $_Ship.ammostorage.{$_DeployableMacro}.count" operation="add"/>
            </do_if>
            <do_if value="$_DeployableAmount lt $_Ship.ammostorage.{$_DeployableMacro}.count">
               <set_value name="$_DeployablesToSell.{$_DeployableMacro}" exact="$_Ship.ammostorage.{$_DeployableMacro}.count - $_DeployableAmount" operation="add"/>
               <set_value name="$_DeployablesToSellAmount"               exact="$_Ship.ammostorage.{$_DeployableMacro}.count - $_DeployableAmount" operation="add"/>
            </do_if>
         </do_for_each>

         <set_value name="$_TotalFreeStorage" exact="($_DeployablesFreeStorage + $_DeployablesToSellAmount)"/>

         <!-- Not enough storage for the wanted Deployables and we are not allowed to sell any. -->
         <!-- Should not occcur, but just in case the script that calls this script has forgotten to check for this. -->
         <do_if value="not $FORCE_RERSTOCK and $_TotalFreeStorage == 0">
            <do_if value="$DEBUG gt 0">
               <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~'"/>
               <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'Our storage is full and we are not allowed to sell any Deployables ~ $FORCE_RERSTOCK is false!'"/>
               <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~\n'"/>
            </do_if>
            <return value="'Failed'"/>
         </do_if>

         <do_if value="$FORCE_RERSTOCK and $_TotalFreeStorage lt $_DeployablesToBuyAmount">

            <!-- We are allowed to sell some Deployables to make room for the wanted Deployables.
                 So let's find out which Deployables we can sell. -->
            <set_value name="$_PossibleSellableDeployables" exact="$_Ship.ammostorage.deployable.table"/>
            <do_for_each name="$_DeployableMacro" valuename="$_DeployableAmount" in="$_DeployablesToBuy">
               <set_value name="$_PossibleSellableDeployables.{$_DeployableMacro}" exact="0" operation="set"/>
            </do_for_each>
            <do_for_each name="$_DeployableMacro" valuename="$_DeployableAmount" in="$_DeployablesToSell">
               <set_value name="$_PossibleSellableDeployables.{$_DeployableMacro}" exact="$_DeployableAmount" operation="subtract"/>
            </do_for_each>
            <set_value name="$_PossibleSellableDeployablesAmount" exact="0"/>
            <do_for_each name="$_DeployableMacro" valuename="$_DeployableAmount" in="$_PossibleSellableDeployables">
               <set_value name="$_PossibleSellableDeployablesAmount" exact="$_DeployableAmount" operation="add"/>
            </do_for_each>

            <!-- Add the Deployables we can sell to the $_DeployablesToSell table. -->
            <do_while value="$_DeployablesToBuyAmount - $_TotalFreeStorage gt 0">
               <wait exact="1ms" comment="In case of an endless loop, the game will freeze if there is no wait."/>
               <do_if value="$_PossibleSellableDeployablesAmount == 0">
                  <break/>
               </do_if>
               <do_for_each name="$_DeployableMacro" valuename="$_DeployableAmount" in="$_PossibleSellableDeployables">
                  <do_if value="$_DeployableAmount gt 0">
                     <set_value name="$_DeployablesToSell.{$_DeployableMacro}"           exact="1" operation="add"/>
                     <set_value name="$_DeployablesToSellAmount"                         exact="1" operation="add"/>
                     <set_value name="$_PossibleSellableDeployables.{$_DeployableMacro}" exact="1" operation="subtract"/>
                     <set_value name="$_PossibleSellableDeployablesAmount"               exact="1" operation="subtract"/>
                     <set_value name="$_TotalFreeStorage"                                exact="1" operation="add"/>
                  </do_if>
               </do_for_each>
            </do_while>

         </do_if>

         <!-- Either we are allowed to sell Deployables to make space and there are not enough,
              or we are not allowed to sell Deployables and we have not enough free storage.
              Cap the deployables we want to buy to the amount of free storage we have. -->
         <do_if value="$_TotalFreeStorage lt $_DeployablesToBuyAmount">
            <do_while value="$_DeployablesToBuyAmount - $_TotalFreeStorage">
               <wait exact="1ms" comment="In case of an endless loop, the game will freeze if there is no wait."/>
               <do_for_each name="$_DeployableMacro" valuename="$_DeployableAmount" in="$_DeployablesToBuy">
                  <do_if value="$_DeployablesToBuyAmount - $_TotalFreeStorage == 0">
                     <break/>
                  </do_if>
                  <set_value name="$_DeployablesToBuy.{$_DeployableMacro}" exact="1" operation="subtract"/>
                  <set_value name="$_DeployablesToBuyAmount"               exact="1" operation="subtract"/>
               </do_for_each>
            </do_while>
         </do_if>

         <!-- Create and populate the table that is used by add_build_to_modify_ship, 
              by first adding all current Deployables, ammo and countermeasures to the table.
              Then remove the Deployables we want to sell and add the Deployables we want to buy. -->
         <set_value name="$_ModifiedEquipmentTable" exact="table[]"/>
         <do_for_each name="$_EquipmentMacro" valuename="$_EquipmentAmount" in="$_Ship.ammostorage.missile.table">
            <set_value name="$_ModifiedEquipmentTable.{$_EquipmentMacro}" exact="$_EquipmentAmount"/>
         </do_for_each>
         <do_for_each name="$_EquipmentMacro" valuename="$_EquipmentAmount" in="$_Ship.ammostorage.countermeasure.table">
            <set_value name="$_ModifiedEquipmentTable.{$_EquipmentMacro}" exact="$_EquipmentAmount"/>
         </do_for_each>
         <do_for_each name="$_EquipmentMacro" valuename="$_EquipmentAmount" in="$_Ship.ammostorage.deployable.table">
            <set_value name="$_ModifiedEquipmentTable.{$_EquipmentMacro}" exact="$_EquipmentAmount"/>
         </do_for_each>
         <do_for_each name="$_EquipmentMacro" valuename="$_EquipmentAmount" in="$_DeployablesToSell">
            <set_value name="$_ModifiedEquipmentTable.{$_EquipmentMacro}" exact="$_DeployablesToSell.{$_EquipmentMacro}" operation="subtract"/>
         </do_for_each>
         <do_for_each name="$_EquipmentMacro" valuename="$_EquipmentAmount" in="$_DeployablesToBuy">
            <set_value name="$_ModifiedEquipmentTable.{$_EquipmentMacro}" exact="$_DeployablesToBuy.{$_EquipmentMacro}" operation="add"/>
         </do_for_each>

         <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->

         <!-- Find Stations where we can restock -->
         <create_list name="$_FoundStations"/>
         <run_script name="'jp.lib.FindStationToEquipAt'" result="$_FoundStations"/>

         <!-- Message ~ Currently, there are no available stations where we could restock our desired equipment.
                        Normally, this should not happen, but if it does, we will just get a message anyway. -->
         <do_if value="$_FoundStations.count == 0">
            <show_help custom="$RESTOCK_TITLE + '\n\n' + {8888888, 60} + '\n' + {8888888, 50}" position="1" allowclose="true" chance="if $SHOW_MESSAGES gt 0 then 100 else 0"/>
            <write_to_logbook title="$RESTOCK_TITLE" text="{8888888, 60} + '\n' + {8888888, 50}" category="upkeep" interaction="showonmap" object="$_Ship" chance="if $WRITE_TO_LOG gt 0 then 100 else 0"/>
            <resume label="FINISH_LBL"/>
         </do_if>

         <!-- When we have Deployables to buy check all Stations if they have the needed resources -->
         <set_value name="$_RestockStation" exact="null"/>
         <do_if value="$_DeployablesToBuyAmount gt 0">
            <set_value name="$_StationWareCheckTable" exact="table[]"/>
            <do_for_each name="$_EquipmentMacro" valuename="$_EquipmentAmount" in="$_DeployablesToBuy">
               <set_value name="$_StationWareCheckTable.{$_EquipmentMacro.ware}" exact="$_EquipmentAmount"/>
            </do_for_each>
            <do_for_each name="$_Station" in="$_FoundStations">
               <do_if value="$_Station.hasresourcesfor.{$_StationWareCheckTable}">
                  <set_value name="$_RestockStation" exact="$_Station"/>
                  <break/>
               </do_if>
            </do_for_each>
            <remove_value name="$_StationWareCheckTable"/>
            <!-- Message ~ At present, all discovered stations are insufficient in the necessary resources to fabricate the required equipment.
                           The intended strategy is to navigate to the nearest station,
                           generate a restock order, and await the subsequent resource replenishment. -->
            <do_if value="$_RestockStation" exact="null">
               <show_help custom="$RESTOCK_TITLE + '\n\n' + {8888888, 60} + '\n' + {8888888, 51}" position="1" allowclose="true" chance="if $SHOW_MESSAGES gt 0 then 100 else 0"/>
               <write_to_logbook title="$RESTOCK_TITLE" text="{8888888, 60} + '\n' + {8888888, 51}" category="upkeep" interaction="showonmap" object="$_Ship" chance="if $WRITE_TO_LOG gt 0 then 100 else 0"/>
            </do_if>
         </do_if>

         <!-- Fall back to the first station if none of them has enough resources, or if we have nothing to buy. -->
         <do_if value="$_RestockStation" exact="null">
            <set_value name="$_RestockStation" exact="$_FoundStations.{1}"/>
         </do_if>

         <!-- Calculate the price for all the Deployables that we want to buy -->
         <set_value name="$_TotalBuyPrice" exact="0Cr"/>
         <do_for_each name="$_EquipmentMacro" valuename="$_EquipmentAmount" in="$_DeployablesToBuy">
            <set_value name="$_TotalBuyPrice" exact="($_RestockStation.buildprice.{$_EquipmentMacro.ware} * $_EquipmentAmount)Cr" operation="add"/>
         </do_for_each>

         <!-- Calculate the price for all the Deployables that we want to sell -->
         <set_value name="$_TotalSellPrice" exact="0Cr"/>
         <do_for_each name="$_EquipmentMacro" valuename="$_EquipmentAmount" in="$_DeployablesToSell">
            <set_value name="$_TotalSellPrice" exact="($_RestockStation.buildprice.{$_EquipmentMacro.ware} * $_EquipmentAmount)Cr" operation="add"/>
         </do_for_each>

         <!-- Calculate the total price for the restock -->
         <set_value name="$_RestockPrice" exact="$_TotalBuyPrice - $_TotalSellPrice"/>

         <!-- We lack the necessary funds to restock the desired equipment. -->
         <do_if value="($_RestockPrice + $PURCHASE_THRESHOLD) gt $_Ship.owner.money">
            <show_help custom="$RESTOCK_TITLE + '\n\n' + {8888888, 60} + '\n' + {8888888, 52}" position="1" allowclose="true" chance="if $SHOW_MESSAGES gt 0 then 100 else 0"/>
            <write_to_logbook title="$RESTOCK_TITLE" text="{8888888, 60} + '\n' + {8888888, 52}" category="upkeep" interaction="showonmap" object="$_Ship" chance="if $WRITE_TO_LOG gt 0 then 100 else 0"/>
            <resume label="FINISH_LBL"/>
         </do_if>

         <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->

         <!-- Create the text for the logbook and the message -->

         <run_script name="'jp.lib.GetFactionColorCode'" result="$_RestockStationOwnerColor">
            <param name="FACTION" value="$_RestockStation.owner"/>
         </run_script>

         <run_script name="'jp.lib.GetFactionColorCode'" result="$_RestockStationSectorOwnerColor">
            <param name="FACTION" value="$_RestockStation.sector.owner"/>
         </run_script>

         <run_script name="'jp.lib.GetFactionRelationColorCode'" result="$_RestockStationOwnerRelationColorCode">
            <param name="FACTION_RELATION" value="$_Ship.owner.relation.{$_RestockStation.relationto.{$_Ship}}.uivalue"/>
         </run_script>

         <set_value name="$_LogText" exact="''"/>
         <set_value name="$_HelpText" exact="''"/>

         <!-- I'll go change my equipment:\nStation: %5%1 [%2]\033X\nRelation: %6%3\033X\nSector: %7%4\033X -->
         <set_value name="$_HelpText" exact="{8888888, 56}.[$_RestockStation.knownname, $_RestockStation.idcode,
                                            $_Ship.owner.relation.{$_RestockStation.relationto.{$_Ship}}.uivalue, $_RestockStation.sector.knownname,
                                            $_RestockStationOwnerColor, $_RestockStationOwnerRelationColorCode, $_RestockStationSectorOwnerColor]"/>

         <set_value name="$_LogText" exact="{8888888, 56}.[$_RestockStation.knownname, $_RestockStation.idcode,
                                            $_Ship.owner.relation.{$_RestockStation.relationto.{$_Ship}}.uivalue, $_RestockStation.sector.knownname,
                                            $_RestockStationOwnerColor, $_RestockStationOwnerRelationColorCode, $_RestockStationSectorOwnerColor]"/>


         <!-- Equipment change cost: %1\n -->
         <set_value name="$_HelpText" exact="{8888888, 57}.[$_RestockPrice.formatted.{'%.s %Cr'}]" operation="add"/>
         <set_value name="$_LogText" exact="{8888888, 57}.[$_RestockPrice.formatted.{'%.s %Cr'}]" operation="add"/>

         <!-- \nI sell equipment for %1 -->
         <do_if value="$_DeployablesToSellAmount gt 0">
            <set_value name="$_HelpText" exact="{8888888, 58}.[$_TotalSellPrice.formatted.{'%.s %Cr'}]" operation="add" chance="if $SHOW_MESSAGES ge 2 then 100 else 0"/>
            <set_value name="$_LogText" exact="{8888888, 58}.[$_TotalSellPrice.formatted.{'%.s %Cr'}]" operation="add" chance="if $WRITE_TO_LOG ge 2 then 100 else 0"/>
            <do_for_each name="$_EquipmentMacro" valuename="$_EquipmentAmount" in="$_DeployablesToSell">
               <set_value name="$_SellPrice" exact="(abs($_RestockStation.buildprice.{$_EquipmentMacro.ware} * $_EquipmentAmount))Cr"/>
               <set_value name="$_HelpText" exact="'\n%1 x %2 ~ %3.'.[$_EquipmentAmount, $_EquipmentMacro.name, $_SellPrice.formatted.{'%.s %Cr'}]" operation="add" chance="if $SHOW_MESSAGES ge 3 then 100 else 0"/>
               <set_value name="$_LogText" exact="'\n%1 x %2 ~ %3.'.[$_EquipmentAmount, $_EquipmentMacro.name, $_SellPrice.formatted.{'%.s %Cr'}]" operation="add" chance="if $WRITE_TO_LOG ge 3 then 100 else 0"/>
            </do_for_each>
            <set_value name="$_HelpText" exact="'\n'" operation="add"/>
            <set_value name="$_LogText" exact="'\n'" operation="add"/>
         </do_if>

         <!-- \nI buy equipment for %1 -->
         <do_if value="$_DeployablesToBuyAmount gt 0">
            <set_value name="$_HelpText" exact="{8888888, 59}.[$_TotalBuyPrice.formatted.{'%.s %Cr'}]" operation="add" chance="if $SHOW_MESSAGES ge 2 then 100 else 0"/>
            <set_value name="$_LogText" exact="{8888888, 59}.[$_TotalBuyPrice.formatted.{'%.s %Cr'}]" operation="add" chance="if $WRITE_TO_LOG ge 2 then 100 else 0"/>
            <do_for_each name="$_EquipmentMacro" valuename="$_EquipmentAmount" in="$_DeployablesToBuy">
               <set_value name="$_BuyPrice" exact="(abs($_RestockStation.buildprice.{$_EquipmentMacro.ware} * $_EquipmentAmount))Cr"/>
               <set_value name="$_HelpText" exact="'\n%1 x %2 ~ %3.'.[$_EquipmentAmount, $_EquipmentMacro.name, $_BuyPrice.formatted.{'%.s %Cr'}]" operation="add" chance="if $SHOW_MESSAGES ge 3 then 100 else 0"/>
               <set_value name="$_LogText" exact="'\n%1 x %2 ~ %3.'.[$_EquipmentAmount, $_EquipmentMacro.name, $_BuyPrice.formatted.{'%.s %Cr'}]" operation="add" chance="if $WRITE_TO_LOG ge 3 then 100 else 0"/>
            </do_for_each>
            <set_value name="$_HelpText" exact="'\n'" operation="add" chance="if $SHOW_MESSAGES ge 2 then 100 else 0"/>
            <set_value name="$_LogText" exact="'\n\n'" operation="add" chance="if $WRITE_TO_LOG ge 2 then 100 else 0"/>
         </do_if>

         <show_help custom="$RESTOCK_TITLE + '\n\n' + $_HelpText" position="1" allowclose="true" chance="if $SHOW_MESSAGES ge 1 then 100 else 0"/>
         <write_to_logbook title="$RESTOCK_TITLE" text="'\n' + $_LogText" category="upkeep" interaction="showonmap" object="$_Ship" chance="if $WRITE_TO_LOG ge 1 then 100 else 0"/>

         <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->

         <add_build_to_modify_ship buildobject="$_Ship" object="$_RestockStation" ammo="$_ModifiedEquipmentTable" price="$_RestockPrice" immediate="true" result="$_ModifyResult"/>
         <wait exact="1ms"/>

         <!-- The process of creating the restock order has failed. -->
         <do_if value="not $_ModifyResult">
            <show_help custom="$RESTOCK_TITLE + '\n\n' + {8888888, 60} + '\n' + {8888888, 53}" position="1" allowclose="true" chance="if $SHOW_MESSAGES gt 0 then 100 else 0"/>
            <write_to_logbook title="$RESTOCK_TITLE" text="{8888888, 60} + '\n' + {8888888, 53}" category="upkeep" interaction="showonmap" object="$_Ship" chance="if $WRITE_TO_LOG gt 0 then 100 else 0"/>
            <resume label="FINISH_LBL"/>
         </do_if>

         <set_value name="$_Result" exact="'Success'"/>

         <label name="FINISH_LBL"/>

         <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->

         <label name="END_LBL"/>
         <do_if value="$DEBUG gt 0">
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'[' + player.systemtime.{'%F - %X'} + '] ' + '~~ ' + $_DebugScriptName + '.xml ~ SCRIPT_END ~~'"/>
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~\n'"/>
         </do_if>

         <return value="$_Result"/>

      </actions>
   </attention>

   <on_abort>
   </on_abort>

</aiscript><?xml version="1.0" encoding="utf-8"?>

<aiscript name="jp.lib.RestockEquipment" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="aiscripts.xsd">

   <params>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <param name="EQUIPMENT_TABLE" default="table[]"/>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <param name="GENERATE_TITLE" default="true"/>
      <param name="RESTOCK_TITLE"  default="''"/>
      <param name="EQUIPMENT_BUYSELL_TEXT" default="'TODO: EQUIPMENT_BUYSELL_TEXT'"/>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <param name="debugchance" default="0"/>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
   </params>

   <init>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <set_value name="$_Ship" exact="this.ship"/>
      <set_value name="$_DefaultOrderParamRef" exact="if $_Ship.defaultorder.id == 'Assist' then $_Ship.commander.defaultorder else $_Ship.defaultorder"/>
      <set_value name="$_Result" exact="'Failed'"/>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <do_if value="$GENERATE_TITLE and $RESTOCK_TITLE == ''">
         <set_value name="$RESTOCK_TITLE" exact="'%1 ~ %2 [%3]'.[$_DefaultOrderParamRef.name, $_Ship.knownname, $_Ship.idcode]"/>
         <substitute_text source="$RESTOCK_TITLE" text="$RESTOCK_TITLE">
            <replace string="'\033#FFCEFBA1# ~ Idle\033X'"   with="''"/>
            <replace string="'\033#FFA95908##ASE-G\033X ~ '" with="''"/>
            <replace string="'\033#FFA95908##AE-S\033X ~ '"  with="''"/>
            <replace string="'\033#FFA95908##AE-G\033X ~ '"  with="''"/>
            <replace string="'\033#FFA95908##CP-S\033X ~ '"  with="''"/>
            <replace string="'\033#FFA95908##CP-G\033X ~ '"  with="''"/>
            <replace string="'\033#FFA95908##DVE-G\033X ~ '" with="''"/>
            <replace string="'\033#FFA95908##SD-S\033X ~ '"  with="''"/>
            <replace string="'\033#FFA95908##SD-G\033X ~ '"  with="''"/>
            <replace string="'\033#FFA95908##SE-S\033X ~ '"  with="''"/>
            <replace string="'\033#FFA95908##SE-G\033X ~ '"  with="''"/>
            <replace string="'\033#FFA95908##TSE-S\033X ~ '" with="''"/>
            <replace string="'\033#FFA95908##TSE-G\033X ~ '" with="''"/>
         </substitute_text>
      </do_if>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <set_value name="$SHOW_MESSAGES" exact="@$_DefaultOrderParamRef.$SHOW_MESSAGES"/>
      <set_value name="$WRITE_TO_LOG" exact="@$_DefaultOrderParamRef.$WRITE_TO_LOG"/>
      <set_value name="$DEBUG" exact="@$_DefaultOrderParamRef.$DEBUG"/>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <do_if value="$DEBUG gt 0">
         <set_value name="$_DebugFolderName" exact="@$_DefaultOrderParamRef.$DEBUG_FOLDER_NAME"/>
         <set_value name="$_DebugScriptName" exact="'jp.lib.RestockEquipment'"/>
         <set_value name="$_DebugFileName" exact="$_Ship.idcode + '.' + $_DebugScriptName + '.xml.log'"/>
      </do_if>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
   </init>

   <attention min="unknown">
      <actions>

         <label name="INIT_LBL"/>
         <do_if value="$DEBUG gt 0">
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~'" append="false"/>
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'[' + player.systemtime.{'%F - %X'} + '] ' + '~~ ' + $_DebugScriptName + '.xml ~ SCRIPT_START ~~' + '\n'"/>
         </do_if>

         <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->

         <label name="RESUME_LBL"/>

         <set_command command="command.resupply"/>
         <set_command_action commandaction="commandaction.calculating"/>

         <create_list name="$_FoundStations"/>
         <run_script name="'jp.lib.FindStationToEquipAt'" result="$_FoundStations"/>

         <!-- Currently, there are no available stations where we could restock our desired equipment. -->
         <do_if value="$_FoundStations.count == 0">
            <show_help custom="$RESTOCK_TITLE + '\n\n' + {8888888, 60} + '\n' + {8888888, 50}" position="1" allowclose="true" chance="if $SHOW_MESSAGES gt 0 then 100 else 0"/>
            <write_to_logbook title="$RESTOCK_TITLE" text="{8888888, 60} + '\n' + {8888888, 50}" category="upkeep" interaction="showonmap" object="$_Ship" chance="if $WRITE_TO_LOG gt 0 then 100 else 0"/>
            <resume label="FINISH_LBL"/>
         </do_if>

         <set_value name="$_WantedLoadoutTable" exact="table[]"/>
         <do_for_each name="$_EquipmentMacro" valuename="$_EquipmentAmount" in="$_Ship.ammostorage.missile.table">
            <set_value name="$_WantedLoadoutTable.{$_EquipmentMacro}" exact="$_EquipmentAmount"/>
         </do_for_each>
         <do_for_each name="$_EquipmentMacro" valuename="$_EquipmentAmount" in="$_Ship.ammostorage.countermeasure.table">
            <set_value name="$_WantedLoadoutTable.{$_EquipmentMacro}" exact="$_EquipmentAmount"/>
         </do_for_each>
         <do_for_each name="$_EquipmentMacro" valuename="$_EquipmentAmount" in="$_Ship.ammostorage.deployable.table">
            <set_value name="$_WantedLoadoutTable.{$_EquipmentMacro}" exact="$_EquipmentAmount"/>
         </do_for_each>
         <do_for_each name="$_EquipmentMacro" valuename="$_EquipmentAmount" in="$EQUIPMENT_TABLE">
            <set_value name="$_WantedLoadoutTable.{$_EquipmentMacro}" exact="$_EquipmentAmount"/>
         </do_for_each>

         <set_value name="$_StationWareCheckTable" exact="table[]"/>
         <do_for_each name="$_EquipmentMacro" valuename="$_EquipmentAmount" in="$EQUIPMENT_TABLE">
            <set_value name="$_StationWareCheckTable.{$_EquipmentMacro.ware}" exact="$_EquipmentAmount - $_Ship.ammostorage.{$_EquipmentMacro}.count"/>
         </do_for_each>
         <set_value name="$_RestockStation" exact="null"/>
         <do_for_each name="$_Station" in="$_FoundStations">
            <do_if value="$_Station.hasresourcesfor.{$_StationWareCheckTable}">
               <set_value name="$_RestockStation" exact="$_Station"/>
               <break/>
            </do_if>
         </do_for_each>
         <remove_value name="$_StationWareCheckTable"/>

         <!-- Currently, all discovered stations lack the necessary resources to manufacture the desired equipment. -->
         <do_if value="$_RestockStation" exact="null">
            <show_help custom="$RESTOCK_TITLE + '\n\n' + {8888888, 60} + '\n' + {8888888, 51}" position="1" allowclose="true" chance="if $SHOW_MESSAGES gt 0 then 100 else 0"/>
            <write_to_logbook title="$RESTOCK_TITLE" text="{8888888, 60} + '\n' + {8888888, 51}" category="upkeep" interaction="showonmap" object="$_Ship" chance="if $WRITE_TO_LOG gt 0 then 100 else 0"/>
            <resume label="FINISH_LBL"/>
         </do_if>

         <set_value name="$_RestockPrice" exact="0Cr"/>
         <do_for_each name="$_EquipmentMacro" valuename="$_EquipmentAmount" in="$EQUIPMENT_TABLE">
            <set_value name="$_RestockPrice" exact="($_RestockStation.buildprice.{$_EquipmentMacro.ware} * ($_EquipmentAmount - $_Ship.ammostorage.{$_EquipmentMacro}.count))Cr" operation="add"/>
         </do_for_each>

         <set_value name="$_NewEquipmentPrice" exact="0Cr"/>
         <do_for_each name="$_EquipmentMacro" valuename="$_EquipmentAmount" in="$EQUIPMENT_TABLE">
            <do_if value="($_EquipmentAmount - $_Ship.ammostorage.{$_EquipmentMacro}.count) gt 0">
               <set_value name="$_NewEquipmentPrice" exact="($_RestockStation.buildprice.{$_EquipmentMacro.ware} * ($_EquipmentAmount - $_Ship.ammostorage.{$_EquipmentMacro}.count))Cr" operation="add"/>
            </do_if>
         </do_for_each>

         <!-- We lack the necessary funds to restock the desired equipment. -->
         <do_if value="($_RestockPrice + 100000Cr) gt $_Ship.owner.money">
            <show_help custom="$RESTOCK_TITLE + '\n\n' + {8888888, 60} + '\n' + {8888888, 52}" position="1" allowclose="true" chance="if $SHOW_MESSAGES gt 0 then 100 else 0"/>
            <write_to_logbook title="$RESTOCK_TITLE" text="{8888888, 60} + '\n' + {8888888, 52}" category="upkeep" interaction="showonmap" object="$_Ship" chance="if $WRITE_TO_LOG gt 0 then 100 else 0"/>
            <resume label="FINISH_LBL"/>
         </do_if>

         <!-- text like: I will proceed to sell placeables, which are worth %1. -->
         <set_value name="$_Price" exact="abs($_NewEquipmentPrice)"/>
         <show_help custom="$RESTOCK_TITLE + '\n\n' + $EQUIPMENT_BUYSELL_TEXT.[$_Price.formatted.{'%.s %Cr'}]" position="1" allowclose="true" chance="if $SHOW_MESSAGES ge 2 then 100 else 0"/>
         <write_to_logbook title="$RESTOCK_TITLE" text="$EQUIPMENT_BUYSELL_TEXT.[$_Price.formatted.{'%.s %Cr'}]" category="upkeep" interaction="showonmap" object="$_Ship" chance="if $WRITE_TO_LOG ge 2 then 100 else 0"/>

         <add_build_to_modify_ship buildobject="$_Ship" object="$_RestockStation" ammo="$_WantedLoadoutTable" price="$_RestockPrice" immediate="true" result="$_ModifyResult"/>
         <wait exact="1ms"/>

         <do_if value="not $_ModifyResult">
            <set_value name="$_ResumeCounter" exact="if not $_ResumeCounter? then 0 else ($_ResumeCounter + 1)"/>
            <do_if value="$_ResumeCounter le 3">
               <wait min="1s" max="2s"/>
               <resume label="RESUME_LBL"/>
            </do_if>
            <!-- The process of creating the restock order has failed. -->
            <show_help custom="$RESTOCK_TITLE + '\n\n' + {8888888, 60} + '\n' + {8888888, 53}" position="1" allowclose="true" chance="if $SHOW_MESSAGES gt 0 then 100 else 0"/>
            <write_to_logbook title="$RESTOCK_TITLE" text="{8888888, 60} + '\n' + {8888888, 53}" category="upkeep" interaction="showonmap" object="$_Ship" chance="if $WRITE_TO_LOG gt 0 then 100 else 0"/>
            <resume label="FINISH_LBL"/>
         </do_if>

         <set_value name="$_Result" exact="'Success'"/>
         
         <label name="FINISH_LBL"/>

         <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->

         <label name="END_LBL"/>
         <do_if value="$DEBUG gt 0">
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'[' + player.systemtime.{'%F - %X'} + '] ' + '~~ ' + $_DebugScriptName + '.xml ~ SCRIPT_END ~~'"/>
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~\n'"/>
         </do_if>

         <return value="$_Result"/>

      </actions>
   </attention>

   <on_abort>
   </on_abort>

</aiscript><?xml version="1.0" encoding="utf-8"?>

<aiscript name="jp.lib.SortByEstimatedTravelTime" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="aiscripts.xsd">

   <params>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <param name="LIST"    default="[]"/>
      <param name="REVERSE" default="false"/>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <param name="debugchance" default="0"/>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
   </params>

   <init>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <set_value name="$_Ship" exact="this.ship"/>
      <set_value name="$_DefaultOrderParamRef" exact="if $_Ship.defaultorder.id == 'Assist' then $_Ship.commander.defaultorder else $_Ship.defaultorder"/>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <set_value name="$DEBUG" exact="@$_DefaultOrderParamRef.$DEBUG"/>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
      <do_if value="$DEBUG gt 0">
         <set_value name="$_DebugFolderName" exact="@$_DefaultOrderParamRef.$DEBUG_FOLDER_NAME"/>
         <set_value name="$_DebugScriptName" exact="'jp.lib.SortByEstimatedTravelTime'"/>
         <set_value name="$_DebugFileName" exact="$_Ship.idcode + '.' + $_DebugScriptName + '.xml.log'"/>
      </do_if>
      <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
   </init>

   <attention min="unknown">
      <actions>

         <label name="INIT_LBL"/>
         <do_if value="$DEBUG gt 0">
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~'" append="false"/>
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'[' + player.systemtime.{'%F - %X'} + '] ' + '~~ ' + $_DebugScriptName + '.xml ~ SCRIPT_START ~~' + '\n'"/>
         </do_if>

         <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->

         <set_command_action commandaction="commandaction.calculating"/>

         <do_if value="@$LIST.{1}.distanceto.{$_Ship}">
            <create_list name="$_SectorTravelTimes"/>
            <do_for_each name="$_ListEntry" in="$LIST">
               <estimate_travel_time ship="$_Ship" start="$_Ship" target="$_ListEntry" result="$_TravelTime"/>
               <append_to_list name="$_SectorTravelTimes" exact="[$_ListEntry, $_TravelTime]"/>
            </do_for_each>
            <sort_list list="$_SectorTravelTimes" sortbyvalue="loop.element.{2}"/>
            <clear_list list="$LIST"/>
            <do_if value="$_SectorTravelTimes.{1}.{1}.isclass.{class.sector}">
               <do_for_each name="$_Sector" in="$_SectorTravelTimes" reverse="true">
                  <do_if value="$_Sector.{1} == $_Ship.sector">
                     <remove_from_list name="$_SectorTravelTimes" exact="$_Sector"/>
                     <append_to_list name="$LIST" exact="$_Ship.sector"/>
                     <break/>
                  </do_if>
               </do_for_each>
            </do_if>
            <do_for_each name="$_SectorTravelTime" in="$_SectorTravelTimes">
               <append_to_list name="$LIST" exact="$_SectorTravelTime.{1}"/>
            </do_for_each>
         </do_if>

         <do_if value="$REVERSE">
            <create_list name="$_ReversedList"/>
            <do_for_each name="$_Entry" in="$LIST" reverse="true">
               <append_to_list name="$_ReversedList" exact="$_Entry"/>
            </do_for_each>
            <clear_list list="$LIST"/>
            <append_list_elements name="$LIST" other="$_ReversedList"/>
         </do_if>

         <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->

         <label name="END_LBL"/>
         <do_if value="$DEBUG gt 0">
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'[' + player.systemtime.{'%F - %X'} + '] ' + '~~ ' + $_DebugScriptName + '.xml ~ SCRIPT_END ~~'"/>
            <debug_to_file directory="$_DebugFolderName" name="$_DebugFileName" text="'~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~\n'"/>
         </do_if>

         <return value="$LIST"/>

      </actions>
   </attention>

</aiscript><?xml version="1.0" encoding="utf-8"?>

<diff xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://x4dynlib.access.ly\libraries\aiscripts.xsd">

   <add sel="//params">
      <param name="IDLE_RETURN_HOME"  type="internal" default="false"/>
   </add>

   <add sel="//create_order[@name='$dockorder'][@object='this.assignedcontrolled']">
      <param name="IDLE_RETURN_HOME" value="$IDLE_RETURN_HOME"/>
   </add>

   <add sel="//interrupts">
      <handler>
         <conditions>
            <event_object_signalled object="this.ship" param="'Cancel_IdleReturnHome'"/>
            <check_value value="$IDLE_RETURN_HOME == true"/>
         </conditions>
         <actions>
            <cancel_order order="this.ship.order"/>
         </actions>
      </handler>
   </add>

</diff><?xml version="1.0" encoding="utf-8"?>

